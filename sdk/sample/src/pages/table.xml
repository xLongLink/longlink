<Page name="Table" icon="table">
  <Hero title="Table demo" subtitle="Sample tabular dataset rendered from XML page schema." />
  <Table
    data='[{"id":"p1","name":"Marketing Website","owner":"Alice","status":"In Progress","budget":"$12,000"},{"id":"p2","name":"Mobile App","owner":"Bruno","status":"Planning","budget":"$35,000"},{"id":"p3","name":"Data Migration","owner":"Carla","status":"Done","budget":"$8,500"}]'
  >
    <Column key="name" label="Project" content="{name}" />
    <Column key="owner" label="Owner" content="{owner}" />
    <Column key="status" label="Status" content="{status}" />
    <Column key="budget" label="Budget" align="right" content="{budget}" />
  </Table>
</Page>
