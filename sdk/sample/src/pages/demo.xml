<Page name="Demo" icon="layout">
  <Hero title="Demo" subtitle="Sample XML-driven page schema served by the SDK." icon="layout" />
  <Button text="Call /sample endpoint" variant="secondary" url="/sample" />
  <Table
    data='[{"id":1,"name":"Alice","active":true},{"id":2,"name":"Bruno","active":false},{"id":3,"name":"Carla","active":true}]'
  >
    <Column key="id" label="ID" content="{id}" />
    <Column key="name" label="Name" content="{name}" />
    <Column key="active" label="Active" content="{active}" />
  </Table>
</Page>
