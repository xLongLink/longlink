<?xml-model href="https://docs.longlink.dev/schema.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<Page name="Cart" icon="shopping-cart">
  <Hero
    title="Internal Shop Cart"
    subtitle="Select approved hardware for your workspace from the internal catalog."
    icon="shopping-cart"
  >
    <Button href="/sample" variant="default">Submit Request</Button>
  </Hero>

  <Columns>
    <Column width="70%">
      <Card>
        <CardHeader>
          <CardTitle>Shop Catalog</CardTitle>
          <CardDescription>Browse approved hardware for your workspace.</CardDescription>
        </CardHeader>
        <CardContent>
          <Table
            data='[{"sku":"HW-MSE-101","name":"Ergo Mouse","category":"Mouse","stock":"18","price":39},{"sku":"HW-MSE-204","name":"Wireless Mouse Pro","category":"Mouse","stock":"7","price":59},{"sku":"HW-KBD-110","name":"Compact Mechanical Keyboard","category":"Keyboard","stock":"12","price":89},{"sku":"HW-KBD-330","name":"Ergo Split Keyboard","category":"Keyboard","stock":"3","price":129},{"sku":"HW-ACC-032","name":"USB-C Dock","category":"Accessory","stock":"5","price":129}]'
          >
            <Column key="sku" label="SKU" content="{sku}" />
            <Column key="name" label="Item" content="{name}" />
            <Column key="category" label="Category" content="{category}" />
            <Column key="stock" label="Stock" content="{stock}" />
            <Column key="price" label="Price" align="right" content="{price}" />
          </Table>
        </CardContent>
      </Card>
    </Column>

    <Column width="30%">
      <Card>
        <CardHeader>
          <CardTitle>Cart</CardTitle>
          <CardDescription>Items queued for approval and checkout.</CardDescription>
        </CardHeader>
        <CardContent>
          <Table
            data='[{"sku":"HW-MSE-204","name":"Wireless Mouse Pro","quantity":1,"status":"Ready"},{"sku":"HW-KBD-110","name":"Compact Mechanical Keyboard","quantity":1,"status":"Ready"},{"sku":"HW-ACC-032","name":"USB-C Dock","quantity":1,"status":"Backorder"}]'
          >
            <Column key="sku" label="SKU" content="{sku}" />
            <Column key="name" label="Item" content="{name}" />
            <Column key="quantity" label="Qty" content="{quantity}" />
            <Column key="status" label="Status" content="{status}" />
          </Table>
        </CardContent>
        <CardFooter>
          <Button href="/sample" variant="default">Submit Request</Button>
        </CardFooter>
      </Card>
    </Column>
  </Columns>
</Page>
