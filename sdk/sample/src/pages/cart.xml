<?xml-model href="https://docs.longlink.dev/schema.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<Page name="Cart" icon="shopping-cart">
  <Hero
    title="Internal Shop Cart"
    subtitle="Select approved hardware for your workspace from the internal catalog."
    icon="shopping-cart"
  >
    <Button href="/sample" variant="default">Submit Request</Button>
  </Hero>

  <Columns>
    <Column span="5">
      <Card>
        <CardHeader>
          <CardTitle>Shop Catalog</CardTitle>
          <CardDescription>Browse approved hardware for your workspace.</CardDescription>
        </CardHeader>
        <CardContent>
          <Table>
            <TableHeader>
              <TableRow>
                <TableHead>SKU</TableHead>
                <TableHead>Item</TableHead>
                <TableHead>Category</TableHead>
                <TableHead>Stock</TableHead>
                <TableHead class="text-right">Price</TableHead>
              </TableRow>
            </TableHeader>
            <TableBody>
              <TableRow>
                <TableCell>HW-MSE-101</TableCell>
                <TableCell>Ergo Mouse</TableCell>
                <TableCell>Mouse</TableCell>
                <TableCell>18</TableCell>
                <TableCell class="text-right">$39</TableCell>
              </TableRow>
              <TableRow>
                <TableCell>HW-MSE-204</TableCell>
                <TableCell>Wireless Mouse Pro</TableCell>
                <TableCell>Mouse</TableCell>
                <TableCell>7</TableCell>
                <TableCell class="text-right">$59</TableCell>
              </TableRow>
              <TableRow>
                <TableCell>HW-KBD-110</TableCell>
                <TableCell>Compact Mechanical Keyboard</TableCell>
                <TableCell>Keyboard</TableCell>
                <TableCell>12</TableCell>
                <TableCell class="text-right">$89</TableCell>
              </TableRow>
              <TableRow>
                <TableCell>HW-KBD-330</TableCell>
                <TableCell>Ergo Split Keyboard</TableCell>
                <TableCell>Keyboard</TableCell>
                <TableCell>3</TableCell>
                <TableCell class="text-right">$129</TableCell>
              </TableRow>
              <TableRow>
                <TableCell>HW-ACC-032</TableCell>
                <TableCell>USB-C Dock</TableCell>
                <TableCell>Accessory</TableCell>
                <TableCell>5</TableCell>
                <TableCell class="text-right">$129</TableCell>
              </TableRow>
            </TableBody>
          </Table>
        </CardContent>
      </Card>
    </Column>

    <Column span="5">
      <Card>
        <CardHeader>
          <CardTitle>Cart</CardTitle>
          <CardDescription>Items queued for approval and checkout.</CardDescription>
        </CardHeader>
        <CardContent>
          <Table>
            <TableHeader>
              <TableRow>
                <TableHead>SKU</TableHead>
                <TableHead>Item</TableHead>
                <TableHead>Qty</TableHead>
                <TableHead>Status</TableHead>
              </TableRow>
            </TableHeader>
            <TableBody>
              <TableRow>
                <TableCell>HW-MSE-204</TableCell>
                <TableCell>Wireless Mouse Pro</TableCell>
                <TableCell>1</TableCell>
                <TableCell>Ready</TableCell>
              </TableRow>
              <TableRow>
                <TableCell>HW-KBD-110</TableCell>
                <TableCell>Compact Mechanical Keyboard</TableCell>
                <TableCell>1</TableCell>
                <TableCell>Ready</TableCell>
              </TableRow>
              <TableRow>
                <TableCell>HW-ACC-032</TableCell>
                <TableCell>USB-C Dock</TableCell>
                <TableCell>1</TableCell>
                <TableCell>Backorder</TableCell>
              </TableRow>
            </TableBody>
          </Table>
        </CardContent>
        <CardFooter>
          <Button href="/sample" variant="default">Submit Request</Button>
        </CardFooter>
      </Card>
    </Column>
  </Columns>
</Page>
