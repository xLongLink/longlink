<Page name="Projects" icon="layout">

  <Hero 
    title="Project Management" 
    subtitle="Manage your projects via REST API" 
  />

  <!-- GLOBAL STATE -->
  <State>
    <Var name="form.name" value="" />
    <Var name="form.owner" value="" />
    <Var name="selectedProject" value="null" />
  </State>

  <!-- DATA SOURCE -->
  <DataSource 
    id="projects"
    url="/api/projects"
    method="GET"
    autoLoad="true"
  />

  <!-- CREATE FORM -->
  <Section title="Create Project">

    <Input
      kind="text"
      label="Project Name"
      bind="form.name"
      placeholder="Enter project name"
    />

    <Input
      kind="text"
      label="Owner"
      bind="form.owner"
      placeholder="Enter owner name"
    />

    <Button
      text="Create Project"
      variant="default"
      action="/api/projects"
      method="POST"
      payload='{
        "name": "{form.name}",
        "owner": "{form.owner}"
      }'
      onSuccess="
        refetch(projects);
        set(form.name, '');
        set(form.owner, '');
      "
    />

  </Section>

  <!-- PROJECT TABLE -->
  <Section title="Project List">

    <Table dataSource="projects">

      <Column key="name" label="Project" content="{name}" />
      <Column key="owner" label="Owner" content="{owner}" />
      <Column key="status" label="Status" content="{status}" />
      <Column key="budget" label="Budget" content="{budget}" align="right" />

      <!-- ROW ACTION -->
      <RowAction
        label="Select"
        onClick="
          set(selectedProject, row);
        "
      />

      <RowAction
        label="Delete"
        action="/api/projects/{id}"
        method="DELETE"
        confirm="Are you sure?"
        onSuccess="refetch(projects)"
      />

    </Table>

  </Section>

  <!-- DETAILS PANEL -->
  <Section 
    title="Project Details" 
    visible="{selectedProject != null}"
  >

    <Text label="Name" value="{selectedProject.name}" />
    <Text label="Owner" value="{selectedProject.owner}" />
    <Text label="Status" value="{selectedProject.status}" />

    <Button
      text="Mark as Done"
      action="/api/projects/{selectedProject.id}/complete"
      method="POST"
      onSuccess="refetch(projects)"
    />

  </Section>

</Page>