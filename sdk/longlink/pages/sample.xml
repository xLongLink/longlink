<Page name="Sample XML" icon="layout">
  <Hero title="XML Component Catalog" subtitle="Reference page for the sample SDK app covering page, menu, layout, form, dialog, tabs, and table elements." icon="layout">
    <Button text="Legacy POST action" variant="outline" url="/sample" />
  </Hero>
  <Menu>
    <MenuSection title="Overview" icon="layout-dashboard">
      <MenuSubSection title="" root="true">
        <Stack gap="24">
          <Card>
            <CardHeader>
              <CardTitle>Runtime Building Blocks</CardTitle>
              <CardDescription>This section shows the current runtime renderer elements working together inside a single XML page.</CardDescription>
            </CardHeader>
            <CardContent>
              <h1>Runtime XML elements</h1>
              <p>The renderer now exposes explicit HTML-style content primitives instead of a generic Text node.</p>
            </CardContent>
          </Card>

          <Columns gap="16">
            <Column span="8">
              <Card>
                <CardHeader>
                  <CardTitle>Fields and Inputs</CardTitle>
                </CardHeader>
                <CardContent>
                  <h4>Name</h4>
                  <Input name="name" placeholder="Full name" />

                  <h4>Role</h4>
                  <Input name="role" placeholder="Role" />

                  <Separator />

                  <h4>Covered elements</h4>
                  <ul>
                    <li>Page</li>
                    <li>Menu</li>
                    <li>Stack</li>
                    <li>Card</li>
                    <li>Input</li>
                    <li>Dialog</li>
                    <li>Tabs</li>
                    <li>Table</li>
                  </ul>
                </CardContent>
              </Card>
            </Column>

            <Column span="4">
              <Card>
                <CardHeader>
                  <CardTitle>Legacy Form Controls</CardTitle>
                  <CardDescription>These components still use their existing prop model, but the card structure is fully native.</CardDescription>
                </CardHeader>
                <CardContent>
                  <Select
                    label="Select"
                    placeholder="Choose a status"
                    options='[{"label":"Draft","value":"draft"},{"label":"Active","value":"active"},{"label":"Archived","value":"archived"}]'
                    submit="Save"
                  />
                  <Switch label="Switch" description="Toggle a simple boolean setting." active="true" />
                  <Checkbox label="Checkbox" description="Example checkbox element." checked="true" />
                  <Range label="Range" description="Legacy slider component." min="0" max="100" step="10" value="[20,80]" />
                  <Textarea label="Textarea" placeholder="Write a note here" description="Standalone multiline input." />
                </CardContent>
              </Card>
            </Column>
          </Columns>

          <Dialog id="sample-dialog">
            <DialogTrigger>
              Open sample dialog
            </DialogTrigger>
            <DialogContent>
              <DialogHeader>
                <DialogTitle>Dialog</DialogTitle>
                <DialogDescription>Dialog content now follows the same explicit composition as shadcn.</DialogDescription>
              </DialogHeader>
              <p>Dialog, DialogTrigger, DialogContent, DialogHeader, DialogTitle, and DialogDescription are available in XML pages.</p>
              <blockquote>Compose dialog structure directly in XML instead of relying on runtime title injection.</blockquote>
            </DialogContent>
          </Dialog>
        </Stack>
      </MenuSubSection>
    </MenuSection>

    <MenuSection title="Tabs" icon="folder">
      <MenuSubSection title="Native Tabs">
        <Tabs defaultValue="runtime-a">
          <TabsList>
            <TabsTrigger value="runtime-a">Runtime A</TabsTrigger>
            <TabsTrigger value="runtime-b">Runtime B</TabsTrigger>
          </TabsList>

          <TabsContent value="runtime-a">
            <Card>
              <CardHeader>
                <CardTitle>Runtime Tabs</CardTitle>
              </CardHeader>
              <CardContent>
                <h2>Tabs renderer</h2>
                <p>Tabs, TabsList, TabsTrigger, and TabsContent support the runtime renderer.</p>
              </CardContent>
            </Card>
          </TabsContent>

          <TabsContent value="runtime-b">
            <Card>
              <CardHeader>
                <CardTitle>Actions</CardTitle>
                <CardAction>
                  <Button text="Run sample POST action" url="/sample" variant="default" />
                </CardAction>
              </CardHeader>
              <CardContent>
                <p>The action is rendered in the card header using the native CardAction slot.</p>
              </CardContent>
            </Card>
          </TabsContent>
        </Tabs>
      </MenuSubSection>
    </MenuSection>

    <MenuSection title="Tables" icon="table">
      <MenuSubSection title="" root="true">
        <Stack gap="24">
          <Card>
            <CardHeader>
              <CardTitle>Runtime Table Markup</CardTitle>
            </CardHeader>
            <CardContent>
              <p>Native table markup remains available beside the higher-level data table component.</p>
              <Table>
                <TableHeader>
                  <TableRow>
                    <TableHead>Element</TableHead>
                    <TableHead>Type</TableHead>
                  </TableRow>
                </TableHeader>
                <TableBody>
                  <TableRow>
                    <TableCell>TableHeader</TableCell>
                    <TableCell>Runtime</TableCell>
                  </TableRow>
                  <TableRow>
                    <TableCell>TableBody</TableCell>
                    <TableCell>Runtime</TableCell>
                  </TableRow>
                  <TableRow>
                    <TableCell>TableRow / TableHead / TableCell</TableCell>
                    <TableCell>Runtime</TableCell>
                  </TableRow>
                </TableBody>
              </Table>
            </CardContent>
          </Card>

          <Card>
            <CardHeader>
              <CardTitle>Legacy Data Table</CardTitle>
            </CardHeader>
            <CardContent>
              <p>Column definitions can still be declared inline in XML.</p>
              <Table
                data='[{"name":"Projects","owner":"Alice","status":"Active"},{"name":"Billing","owner":"Bruno","status":"Draft"},{"name":"Security","owner":"Carla","status":"Archived"}]'
              >
                <Column key="name" label="Name" content="{name}" />
                <Column key="owner" label="Owner" content="{owner}" />
                <Column key="status" label="Status" content="{status}" />
              </Table>
            </CardContent>
          </Card>
        </Stack>
      </MenuSubSection>
    </MenuSection>

    <MenuSection title="Legacy Layout" icon="columns-3">
      <MenuSubSection title="" root="true">
        <Columns widths="[2,1]">
          <Column width="2">
            <Card>
              <CardHeader>
                <CardTitle>Legacy Columns</CardTitle>
              </CardHeader>
              <CardContent>
                <p>Columns and Column also support the older widths and width props.</p>
              </CardContent>
            </Card>
          </Column>

          <Column width="1">
            <Card>
              <CardHeader>
                <CardTitle>Legacy Button and Separator</CardTitle>
              </CardHeader>
              <CardContent>
                <Button text="Call legacy /sample action" variant="secondary" url="/sample" />
                <Separator />
                <Input kind="text" label="Legacy Input" placeholder="Legacy input component" description="Rendered through the legacy path." submit="Save" />
                <h3>Content primitives</h3>
                <p>Use explicit elements like h1, p, and blockquote instead of a generic text wrapper.</p>
                <code>&lt;blockquote&gt;Quoted content&lt;/blockquote&gt;</code>
              </CardContent>
              <CardFooter>
                <p>CardFooter is available as a dedicated slot.</p>
              </CardFooter>
            </Card>
          </Column>
        </Columns>
      </MenuSubSection>
    </MenuSection>
  </Menu>
</Page>
