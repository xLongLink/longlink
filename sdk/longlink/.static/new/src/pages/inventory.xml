<?xml-model href="https://longlink.dev/docs/schema.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<longlink name="Inventory" icon="package-plus">
    <Query id="items" path="/inventory" />
    <State
        id="inventory"
        sku="SKU-001"
        name="Warehouse Widget"
        quantity="10"
    />

    <Hero icon="package-plus">
        <HeroTitle i18n="Inventory" />
        <HeroDescription i18n="Track inventory rows owned by this application schema while LongLink resolves platform users from the shared users table." />
        <HeroAction>
            <Dialog>
                <DialogTrigger>
                    <Button>
                        <P i18n="Create item" />
                    </Button>
                </DialogTrigger>
                <DialogContent>
                    <Stack>
                        <DialogTitle>
                            <P i18n="Create inventory item" />
                        </DialogTitle>
                        <DialogDescription>
                            <P i18n="Create an application-owned inventory item. The current LongLink user is recorded automatically." />
                        </DialogDescription>

                        <Grid columns="2">
                            <Field>
                                <FieldLabel htmlFor="inventory-sku" i18n="SKU" />
                                <Input id="inventory-sku" value="$inventory.sku" placeholder="SKU-001" />
                                <FieldDescription i18n="Unique stock keeping unit for this item." />
                            </Field>

                            <Field>
                                <FieldLabel htmlFor="inventory-quantity" i18n="Quantity" />
                                <Input id="inventory-quantity" type="number" value="$inventory.quantity" placeholder="10" />
                                <FieldDescription i18n="Current quantity available in inventory." />
                            </Field>
                        </Grid>

                        <Field>
                            <FieldLabel htmlFor="inventory-name" i18n="Name" />
                            <Input id="inventory-name" value="$inventory.name" placeholder="Warehouse Widget" />
                            <FieldDescription i18n="Human-readable item name." />
                        </Field>

                        <Field orientation="horizontal">
                            <FieldLabel></FieldLabel>
                            <Action
                                action="/inventory"
                                method="POST"
                                invalidate='${["items"]}'
                                json="${{ sku: inventory.sku, name: inventory.name, quantity: inventory.quantity }}"
                            >
                                <Button i18n="Save item" />
                            </Action>
                        </Field>
                    </Stack>
                </DialogContent>
            </Dialog>
        </HeroAction>
    </Hero>

    <Card>
        <Table>
            <Thead>
                <Tr>
                    <Th i18n="SKU" />
                    <Th i18n="Name" />
                    <Th i18n="Qty" />
                    <Th i18n="Created by" />
                </Tr>
            </Thead>
            <Tbody>
                <Tr if="${items.length in [0]}">
                    <Td i18n="No inventory items yet." />
                    <Td />
                    <Td />
                    <Td />
                </Tr>
                <For each="$items" as="item">
                    <Tr>
                        <Td value="${item.sku}" />
                        <Td value="${item.name}" />
                        <Td value="${item.quantity}" />
                        <Td value="${item.created_by.name}" />
                    </Tr>
                </For>
            </Tbody>
        </Table>
    </Card>
</longlink>
