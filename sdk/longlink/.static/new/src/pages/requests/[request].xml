<?xml-model href="https://longlink.dev/docs/schema.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<longlink name="Requests" icon="clipboard-list">
    <Query id="request" path="/api/requests/${params.request}" />
    <Query id="attachments" path="/api/requests/${params.request}/attachments" />
    <State id="attachment" file="${null}" />

    <Stack>
        <A to="/requests" i18n="requests.detail.back">
            <Icon name="list" />
        </A>
        <H1 i18n="requests.detail.title" />
        <P i18n="requests.detail.description" />
    </Stack>

    <Grid columns="2">
        <Stack>
            <H2 i18n="requests.detail.summary" />
            <Flex space="between">
                <P value="$request.title" />
                <P value="$request.status" />
            </Flex>
            <P value="${`${request.vendor} - CHF ${request.amount}`}" />
            <P value="$request.justification" />
            <P value="${`Created by ${request.created_by.name}`}" />
            <P if="${request.status in ['approved']}" i18n="requests.detail.approvedNote" />
            <P if="${request.status in ['rejected']}" i18n="requests.detail.rejectedNote" />

            <ButtonGroup>
                <ButtonGroupText i18n="requests.actions.decision" />
                <Action action="/api/requests/${params.request}/status" method="PATCH" invalidate='${["request"]}' json='${{ status: "approved" }}'>
                    <Button i18n="requests.actions.approve">
                        <Icon name="check" />
                    </Button>
                </Action>
                <ButtonGroupSeparator />
                <Action action="/api/requests/${params.request}/status" method="PATCH" invalidate='${["request"]}' json='${{ status: "rejected" }}'>
                    <Button variant="outline" i18n="requests.actions.reject">
                        <Icon name="x" />
                    </Button>
                </Action>
                <Action action="/api/requests/${params.request}/status" method="PATCH" invalidate='${["request"]}' json='${{ status: "submitted" }}'>
                    <Icon name="rotate-ccw" />
                </Action>
            </ButtonGroup>
        </Stack>

        <Stack>
            <H2 i18n="requests.attachments.title" />
            <Field>
                <FieldLabel htmlFor="attachment-file" i18n="requests.attachments.file" />
                <Input id="attachment-file" type="file" value="$attachment.file" />
                <FieldDescription i18n="requests.attachments.help" />
            </Field>
            <Action
                action="/api/requests/${params.request}/attachments"
                method="POST"
                invalidate='${["attachments"]}'
                form="${{ file: attachment.file }}"
            >
                <Button disabled="${attachment.file in [null]}" i18n="requests.attachments.upload" />
            </Action>
        </Stack>
    </Grid>

    <DataTable data="$attachments" as="attachment" empty="No attachments uploaded yet.">
        <DataColumn field="name" header="File" />
        <DataColumn field="size" header="Bytes" />

        <DataColumn>
            <DataHeader i18n="requests.attachments.actions" />
            <DataCell>
                <Flex>
                    <A href="$attachment.download_url" i18n="requests.attachments.download">
                        <Icon name="download" />
                    </A>
                    <Action action="$attachment.download_url" method="DELETE" invalidate='${["attachments"]}'>
                        <Button variant="outline" size="sm" i18n="requests.attachments.delete" />
                    </Action>
                </Flex>
            </DataCell>
        </DataColumn>
    </DataTable>
</longlink>
