<?xml-model href="https://longlink.dev/docs/schema.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<longlink name="Requests" icon="clipboard-list">
    <Query id="requests" path="/api/requests" />
    <State
        id="draft"
        title="Laptop for field audit"
        amount="1800"
        vendor="Acme Hardware"
        justification="Field auditors need a dedicated machine for onsite audit work."
    />

    <Stack gap="3">
        <Heading level="1" i18n="requests.title" />
        <Text as="p" color="secondary" i18n="requests.description" />
        <Dialog i18n="requests.create.title" triggerLabel="New request" purpose="form">
            <Stack gap="3">
                <Text as="p" i18n="requests.create.description" />
                <Heading level="2" type="display-3" i18n="requests.create.section" />
                <FormLayout>
                    <TextInput
                        i18n="requests.fields.title"
                        description="Use a short, searchable name."
                        value="$draft.title"
                        isRequired="true"
                    />
                    <TextInput i18n="requests.fields.vendor" value="$draft.vendor" isRequired="true" />
                    <NumberInput i18n="requests.fields.amount" units="CHF" value="$draft.amount" min="0" isRequired="true" />
                    <TextArea i18n="requests.fields.justification" rows="4" value="$draft.justification" isRequired="true" />
                </FormLayout>
                <Action
                    action="/api/requests"
                    method="POST"
                    invalidate='${["requests"]}'
                    json="${{ title: draft.title, amount: draft.amount, vendor: draft.vendor, justification: draft.justification }}"
                >
                    <Button isDisabled="${draft.title in ['']}" variant="primary" i18n="requests.create.submit" />
                </Action>
            </Stack>
        </Dialog>
    </Stack>

    <Text i18n="requests.count" count="${requests.length}" />

    <Table data="$requests" rowName="request" idKey="id" emptyLabel="No purchase requests yet." hasHover="true">
        <TableColumn key="request" i18n="requests.table.request">
            <Stack gap="1">
                <Link to="/requests/${request.id}" i18n="requests.table.open" />
                <Text i18n="requests.table.title" values="${{ title: request.title }}" />
            </Stack>
        </TableColumn>
        <TableColumn key="vendor" field="vendor" i18n="requests.table.vendor" />
        <TableColumn key="amount" i18n="requests.table.amount">
            <Text value="${`CHF ${request.amount}`}" hasTabularNumbers="true" />
        </TableColumn>
        <TableColumn key="status" i18n="requests.table.status">
            <Badge variant="info" label="$request.status" />
        </TableColumn>
        <TableColumn key="createdBy" field="created_by.name" i18n="requests.table.createdBy" />
    </Table>
</longlink>
