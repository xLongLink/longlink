<?xml-model href="https://longlink.dev/docs/schema.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<longlink>
    <State
        id="form"
        name="Evil Rabbit"
        username="evil.rabbit"
        email="ada@longlink.dev"
        password=""
        team="ops"
        role="operator"
        notes="Draft notes for the account review."
    />

    <Stack>
        <H3 i18n="examples.form.title" />
        <P i18n="examples.form.description" />

        <Grid columns="2">
            <Field>
                <FieldLabel htmlFor="name" i18n="examples.form.name.label" />
                <Input id="name" autoComplete="name" value="$form.name" placeholder="Evil Rabbit" />
                <FieldDescription i18n="examples.form.name.description" />
            </Field>

            <Field>
                <FieldLabel htmlFor="username" i18n="examples.form.username.label" />
                <InputGroup>
                    <InputGroupAddon>
                        <Icon name="user" />
                    </InputGroupAddon>
                    <InputGroupInput
                        id="username"
                        autoComplete="username"
                        placeholder="evil.rabbit"
                        value="$form.username"
                    />
                    <InputGroupButton i18n="examples.form.username.check" />
                </InputGroup>
            </Field>
        </Grid>

        <Grid columns="2">
            <Field>
                <FieldLabel htmlFor="email" i18n="examples.form.email.label" />
                <InputGroup>
                    <InputGroupAddon>
                        <Icon name="mail" />
                    </InputGroupAddon>
                    <InputGroupInput
                        id="email"
                        autoComplete="email"
                        placeholder="ada@longlink.dev"
                        value="$form.email"
                    />
                    <InputGroupButton i18n="examples.form.email.invite" />
                </InputGroup>
            </Field>

            <Field>
                <FieldLabel htmlFor="team" i18n="examples.form.team.label" />
                <Select value="$form.team">
                    <SelectTrigger>
                        <SelectValue i18n="examples.form.team.placeholder" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectLabel i18n="examples.form.team.group" />
                            <SelectItem value="ops" i18n="examples.form.team.operations" />
                            <SelectItem value="support" i18n="examples.form.team.support" />
                            <SelectItem value="product" i18n="examples.form.team.product" />
                        </SelectGroup>
                    </SelectContent>
                </Select>
            </Field>
        </Grid>

        <Grid columns="2">
            <Field>
                <FieldLabel htmlFor="password" i18n="examples.form.password.label" />
                <Input id="password" type="password" autoComplete="new-password" placeholder="password" value="$form.password" />
            </Field>

            <Field>
                <FieldLabel htmlFor="role" i18n="examples.form.role.label" />
                <Select value="$form.role">
                    <SelectTrigger>
                        <SelectValue i18n="examples.form.role.placeholder" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectLabel i18n="examples.form.role.group" />
                            <SelectItem value="operator" i18n="examples.form.role.operator" />
                            <SelectItem value="manager" i18n="examples.form.role.manager" />
                            <SelectItem value="admin" i18n="examples.form.role.admin" />
                        </SelectGroup>
                    </SelectContent>
                </Select>
            </Field>
        </Grid>

        <Field>
            <FieldLabel htmlFor="notes" i18n="examples.form.notes.label" />
            <Textarea id="notes" label="Notes" rows="4" value="$form.notes" />
            <FieldDescription i18n="examples.form.notes.description" />
        </Field>

        <Field orientation="horizontal">
            <FieldLabel></FieldLabel>
            <Button variant="destructive" i18n="examples.form.actions.cancel" />
            <Action
                action="/form"
                method="POST"
                json="${{ name: form.name, username: form.username, email: form.email, password: form.password, team: form.team, role: form.role, notes: form.notes }}"
            >
                <Button i18n="examples.form.actions.submit" />
            </Action>
        </Field>
    </Stack>
</longlink>
