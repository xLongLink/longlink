<?xml-model href="https://longlink.dev/docs/schema.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<longlink name="Settings" icon="settings-2">
    <State id="profile" owner="Operations Desk" costCenter="OPS-100" note="Approve standard equipment within the monthly budget." />
    <State id="reviewer" name="Mira Tanner" initials="MT" badge="Approver" avatarUrl="https://api.dicebear.com/9.x/initials/svg?seed=Mira%20Tanner" />
    <State id="draftLink" label="Vendor quote" />
    <State id="quickLinks" value='${[]}' />
    <State id="emailUpdates" value="true" />
    <State id="notifications" value="true" />
    <State id="pinned" value="false" />
    <State id="budgetLimit" value="2500" />

    <Stack>
        <H1 i18n="settings.title" />
        <P i18n="settings.description" />
    </Stack>

    <Menu defaultValue="application">
        <MenuSection value="application" icon="box" i18n="settings.sections.application">
            <Stack>
                <H2 i18n="settings.sections.application" />
                <P i18n="settings.application.description" />
                <Stack>
                    <FieldLegend i18n="settings.application.legend" />
                    <Flex space="between">
                        <Avatar>
                            <AvatarImage src="$reviewer.avatarUrl" alt="$reviewer.name" />
                            <AvatarFallback>
                                <P value="$reviewer.initials" />
                            </AvatarFallback>
                            <AvatarBadge>
                                <P value="$reviewer.badge" />
                            </AvatarBadge>
                        </Avatar>
                        <P i18n="settings.application.reviewer" />
                    </Flex>

                    <Field>
                        <FieldLabel htmlFor="owner" i18n="settings.application.owner" />
                        <Input id="owner" value="$profile.owner" />
                        <FieldDescription i18n="settings.application.ownerHelp" />
                    </Field>

                    <Field>
                        <FieldLabel htmlFor="cost-center" i18n="settings.application.costCenter" />
                        <InputGroup>
                            <InputGroupAddon>
                                <Icon name="building-2" />
                            </InputGroupAddon>
                            <InputGroupInput id="cost-center" value="$profile.costCenter" />
                            <InputGroupButton i18n="settings.application.lookup" />
                        </InputGroup>
                    </Field>

                    <Field>
                        <FieldLabel htmlFor="note" i18n="settings.application.note" />
                        <InputGroup>
                            <InputGroupTextarea id="note" rows="4" value="$profile.note" />
                            <InputGroupAddon align="block-end">
                                <InputGroupText i18n="settings.application.noteHelp" />
                            </InputGroupAddon>
                        </InputGroup>
                    </Field>

                    <H4 i18n="settings.application.runbook" />
                    <P>
                        <B i18n="settings.application.bold" />
                        <U i18n="settings.application.underlined" />
                        <S i18n="settings.application.outdated" />
                    </P>
                    <P>
                        <Code i18n="settings.application.code" />
                        <Sup i18n="settings.application.sup" />
                        <Sub i18n="settings.application.sub" />
                    </P>
                    <Br />
                    <Pre lang="json" i18n="settings.application.payload" />
                </Stack>
            </Stack>
            <MenuSubSection value="profile" i18n="settings.sections.profile">
                <P i18n="settings.application.profileTip" />
            </MenuSubSection>
        </MenuSection>

        <MenuSection value="preferences" icon="bell" i18n="settings.sections.preferences">
            <Stack>
                <H2 i18n="settings.sections.preferences" />
                <P i18n="settings.preferences.description" />
                <Stack>
                    <FieldLegend i18n="settings.preferences.legend" />
                    <Field orientation="horizontal">
                        <Checkbox id="email-updates" checked="$emailUpdates" />
                        <FieldContent>
                            <Label htmlFor="email-updates" i18n="settings.preferences.email" />
                            <FieldDescription i18n="settings.preferences.emailHelp" />
                        </FieldContent>
                    </Field>

                    <Field orientation="horizontal">
                        <Switch id="notifications" checked="$notifications" />
                        <FieldContent>
                            <FieldTitle i18n="settings.preferences.notifications" />
                            <FieldDescription i18n="settings.preferences.notificationsHelp" />
                        </FieldContent>
                    </Field>

                    <Field>
                        <FieldLabel htmlFor="budget-limit" i18n="settings.preferences.limit" />
                        <Slider id="budget-limit" min="500" max="10000" step="500" value="$budgetLimit" />
                        <P value="${`Auto-approve up to CHF ${budgetLimit.value}`}" />
                    </Field>

                    <Toggle pressed="$pinned">
                        <Icon name="pin" />
                        <P i18n="settings.preferences.pin" />
                    </Toggle>
                </Stack>
            </Stack>
        </MenuSection>

        <MenuSection value="workflow" icon="sliders-horizontal" i18n="settings.sections.workflow">
            <Stack>
                <H2 i18n="settings.sections.workflow" />
                <P i18n="settings.workflow.description" />
                <Stack>
                    <Field>
                        <FieldLabel i18n="settings.workflow.owner" />
                        <RadioGroup defaultValue="manager">
                            <RadioGroupItem value="manager" i18n="settings.workflow.manager" />
                            <RadioGroupItem value="finance" i18n="settings.workflow.finance" />
                            <RadioGroupItem value="owner" i18n="settings.workflow.ownerRole" />
                        </RadioGroup>
                    </Field>

                    <Field>
                        <FieldLabel i18n="settings.workflow.tags" />
                        <ToggleGroup type="multiple" defaultValue='${["finance"]}'>
                            <ToggleGroupItem value="finance">
                                <Icon name="banknote" />
                            </ToggleGroupItem>
                            <ToggleGroupItem value="equipment">
                                <Icon name="laptop" />
                            </ToggleGroupItem>
                            <ToggleGroupItem value="travel">
                                <Icon name="plane" />
                            </ToggleGroupItem>
                        </ToggleGroup>
                    </Field>

                    <Field>
                        <FieldLabel htmlFor="risk" i18n="settings.workflow.risk" />
                        <Select defaultValue="medium">
                            <SelectTrigger>
                                <SelectValue i18n="settings.workflow.riskPlaceholder" />
                            </SelectTrigger>
                            <SelectContent>
                                <SelectGroup>
                                    <SelectLabel i18n="settings.workflow.riskGroup" />
                                    <SelectItem value="low" i18n="settings.workflow.low" />
                                    <SelectItem value="medium" i18n="settings.workflow.medium" />
                                    <SelectSeparator />
                                    <SelectItem value="high" i18n="settings.workflow.high" />
                                </SelectGroup>
                            </SelectContent>
                        </Select>
                    </Field>
                </Stack>
            </Stack>
        </MenuSection>

        <MenuSection value="links" icon="link" i18n="settings.sections.links">
            <Stack>
                <H2 i18n="settings.sections.links" />
                <P i18n="settings.links.description" />
                <Stack>
                    <FieldLegend i18n="settings.links.legend" />
                    <Field>
                        <FieldLabel htmlFor="quick-link" i18n="settings.links.label" />
                        <Input id="quick-link" value="$draftLink.label" />
                    </Field>
                    <ButtonGroup>
                        <ButtonGroupText i18n="settings.links.actions" />
                        <Button append="${'quickLinks.value'}" item="${{ label: draftLink.label }}" disabled="${draftLink.label in ['']}" i18n="settings.links.add" />
                        <ButtonGroupSeparator />
                        <Action invalidate='${["quickLinks"]}'>
                            <Button variant="outline" i18n="settings.links.reset" />
                        </Action>
                    </ButtonGroup>
                    <P if="${quickLinks.value.length in [0]}" i18n="settings.links.empty" />
                    <For each="$quickLinks.value" as="link">
                        <Badge variant="outline" value="$link.label" />
                    </For>
                </Stack>
            </Stack>
        </MenuSection>
    </Menu>
</longlink>
