<?xml-model href="https://longlink.dev/docs/schema.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<longlink name="Quote" icon="file-text">
    <Hero icon="file-text">
        <HeroTitle i18n="examples.quote.title" />
        <HeroDescription i18n="examples.quote.description" />
        <HeroAction>
            <Button variant="outline" size="sm" i18n="examples.quote.actions.copy">
                <Icon name="copy" />
            </Button>
        </HeroAction>
    </Hero>

    <Columns>
        <Column width="75">
            <Tabs defaultValue="items">
                <Tab value="items" i18n="examples.quote.tabs.items">
                    <Table>
                        <Thead>
                            <Tr>
                                <Th i18n="examples.quote.table.item" />
                                <Th i18n="examples.quote.table.quantity" />
                                <Th i18n="examples.quote.table.rate" />
                                <Th i18n="examples.quote.table.amount" />
                            </Tr>
                        </Thead>
                        <Tbody>
                            <Tr>
                                <Td i18n="examples.quote.items.discovery" />
                                <Td i18n="1" />
                                <Td i18n="$1,200" />
                                <Td i18n="$1,200" />
                            </Tr>
                            <Tr>
                                <Td i18n="examples.quote.items.implementation" />
                                <Td i18n="3" />
                                <Td i18n="$900" />
                                <Td i18n="$2,700" />
                            </Tr>
                            <Tr>
                                <Td i18n="examples.quote.items.review" />
                                <Td i18n="2" />
                                <Td i18n="$450" />
                                <Td i18n="$900" />
                            </Tr>
                        </Tbody>
                        <Tfoot>
                            <Tr>
                                <Td i18n="examples.quote.table.total" />
                                <Td i18n="6" />
                                <Td />
                                <Td i18n="$4,800" />
                            </Tr>
                        </Tfoot>
                    </Table>
                </Tab>

                <Tab value="conditions" i18n="examples.quote.tabs.conditions">
                    <Stack>
                        <Badge variant="outline" i18n="examples.quote.conditions.status" />
                        <P i18n="examples.quote.conditions.description" />
                        <Ul>
                            <Li i18n="examples.quote.conditions.pricing" />
                            <Li i18n="examples.quote.conditions.deposit" />
                            <Li i18n="examples.quote.conditions.scope" />
                        </Ul>
                    </Stack>
                </Tab>

                <Tab value="address" i18n="examples.quote.tabs.address">
                    <Stack>
                        <H3 i18n="examples.quote.address.title" />
                        <P i18n="examples.quote.address.description" />
                        <Field>
                            <FieldLabel htmlFor="company" i18n="examples.quote.address.company" />
                            <Input id="company" value="Ada Labs" />
                        </Field>
                        <Field>
                            <FieldLabel htmlFor="street" i18n="examples.quote.address.street" />
                            <Input id="street" value="123 Longlink Ave" />
                        </Field>
                        <Grid columns="2">
                            <Field>
                                <FieldLabel htmlFor="city" i18n="examples.quote.address.city" />
                                <Input id="city" value="Berlin" />
                            </Field>
                            <Field>
                                <FieldLabel htmlFor="postal" i18n="examples.quote.address.postal" />
                                <Input id="postal" value="10115" />
                            </Field>
                        </Grid>
                    </Stack>
                </Tab>

                <Tab value="texts" i18n="examples.quote.tabs.texts">
                    <Stack>
                        <Card>
                            <Stack>
                                <P i18n="examples.quote.texts.intro.title" />
                                <P i18n="examples.quote.texts.intro.description" />
                                <Textarea rows="4" value="Thanks for reviewing the quote. The summary below reflects the current scope and pricing." />
                            </Stack>
                        </Card>
                        <Card>
                            <Stack>
                                <P i18n="examples.quote.texts.footer.title" />
                                <P i18n="examples.quote.texts.footer.description" />
                                <Textarea rows="3" value="Reply with approval or change requests before the end of the week." />
                            </Stack>
                        </Card>
                    </Stack>
                </Tab>

                <Tab value="settings" i18n="examples.quote.tabs.settings">
                    <Stack>
                        <H3 i18n="examples.quote.settings.title" />
                        <P i18n="examples.quote.settings.description" />
                        <Grid columns="2">
                            <Field orientation="horizontal">
                                <Switch id="tax" defaultChecked="true" />
                                <FieldLabel htmlFor="tax" i18n="examples.quote.settings.tax" />
                            </Field>
                            <Field orientation="horizontal">
                                <Switch id="discount" defaultChecked="false" />
                                <FieldLabel htmlFor="discount" i18n="examples.quote.settings.discount" />
                            </Field>
                        </Grid>
                        <Field>
                            <FieldLabel i18n="examples.quote.settings.status.label" />
                            <RadioGroup name="status" defaultValue="draft">
                                <RadioGroupItem value="draft" i18n="examples.quote.settings.status.draft" />
                                <RadioGroupItem value="sent" i18n="examples.quote.settings.status.sent" />
                                <RadioGroupItem value="approved" i18n="examples.quote.settings.status.approved" />
                            </RadioGroup>
                        </Field>
                    </Stack>
                </Tab>
            </Tabs>
        </Column>

        <Column width="25">
            <Stack>
                <P i18n="examples.quote.quickActions.description" />
                <A href="/quotes/send" active="hover" i18n="examples.quote.quickActions.send">
                    <Icon name="mail" />
                </A>
                <A href="/quotes/pdf" active="hover" i18n="examples.quote.quickActions.download">
                    <Icon name="download" />
                </A>
                <A href="/quotes/duplicate" active="hover" i18n="examples.quote.quickActions.duplicate">
                    <Icon name="copy" />
                </A>
                <Hr />
                <Badge variant="outline" i18n="examples.quote.quickActions.status" />
            </Stack>
        </Column>
    </Columns>
</longlink>
