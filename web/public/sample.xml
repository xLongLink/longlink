<Page name="Sample">
    <Hero icon="sparkles">
        <HeroTitle>Component Playground</HeroTitle>
        <HeroDescription>Live XML sample for testing web components without touching the API.</HeroDescription>
        <HeroContent>
            <Badge variant="secondary">New</Badge>
            <Button href="/pricing" variant="outline">Open pricing</Button>
        </HeroContent>
    </Hero>


    <p>This page is loaded from and rendered at</p>
    <Divider />
    <p>
        <Button href="/pricing" variant="outline">Open pricing</Button>
    </p>
    <p>
        <Input placeholder="Type to test the input" value="Live preview" />
    </p>
    <p>
        <Input placeholder="Number input" type="number" value="42" />
    </p>
    <p>
        <Badge variant="outline">Preview</Badge>
    </p>

    <p>Rendered components:</p>
    <For each='{["Hero", "Badge", "Button", "Divider", "Input"]}' as="name">
        <p>{index + 1}. {name}</p>
    </For>

</Page>
