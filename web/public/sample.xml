<?xml-model href="https://docs.longlink.dev/schema.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<longlink>
    <Tabs defaultValue="text">
            <TabsList variant="line">
                <TabsTrigger value="text">Text</TabsTrigger>
                <TabsTrigger value="form">Form</TabsTrigger>
                <TabsTrigger value="item">Item</TabsTrigger>
                <TabsTrigger value="menu">Menu</TabsTrigger>
                <TabsTrigger value="grid">Grid</TabsTrigger>
            </TabsList>
        <TabsContent value="text">
            <H1>Basic Html Elements are Supported</H1>
            <P>
                The import pipeline is now stable. We finished the retry fix for
                <Code>customer_sync</Code>
                , and the
                nightly run completed without manual intervention.
            </P>
            <H2>What changed</H2>
            <P>
                The team tightened validation on
                <B>customer IDs</B>
                , removed one
                <S>temporary bypass</S>
                , and kept the
                rollout limited to the staging workspace. The result is a cleaner path from source data to
                <TooltipProvider>
                    <Tooltip>
                        <TooltipTrigger>
                            <U>dashboard output</U>.
                        </TooltipTrigger>
                        <TooltipContent side="top">This output powers the dashboard summary.</TooltipContent>
                    </Tooltip>
                </TooltipProvider>
            </P>
            <H3>Today’s checklist</H3>
            <Ul>
                <Li>Confirm the summary totals match the warehouse export.</Li>
                <Li>
                    Review any records marked with H<Sub>2</Sub>O-style test labels.
                </Li>
                <Li>
                    Watch the next deploy window at 10<Sup>30</Sup> for regressions.
                </Li>
            </Ul>
            <H3>Follow-up steps</H3>
            <Ol>
                <Li>Share the digest with ops and support.</Li>
                <Li>Validate the next sync against the staging workspace.</Li>
                <Li>Close the ticket after the report refreshes.</Li>
            </Ol>
            <H4>Notes</H4>
            <P>
                For the deeper walkthrough, open
                <A href="/icons" active="hover">the icon catalog</A>
                or inspect the generated report
                after the next sync.
            </P>
        </TabsContent>
        <TabsContent value="form">
            <State
                id="profile"
                name="Evil Rabbit"
                username="evil.rabbit"
                email="ada@longlink.dev"
                team="ops"
                password=""
                timezone="utc"
                notes="Draft notes for the account review."
                newsletter="true"
                autosave="true"
                priority="medium"
            />
            <State id="budget" value="50" />
            <FieldSet>
                <FieldLegend>Account profile</FieldLegend>
                <FieldDescription>A denser backoffice form with inline controls and grouped actions.</FieldDescription>
                <FieldGroup>
                    <Grid columns="2">
                        <Field>
                            <FieldLabel htmlFor="name">Full name</FieldLabel>
                            <Input id="name" autoComplete="name" placeholder="Evil Rabbit" value="$profile.name" />
                            <FieldDescription>This appears on invoices and emails.</FieldDescription>
                        </Field>
                        <Field>
                            <FieldLabel htmlFor="username">Username</FieldLabel>
                            <InputGroup>
                                <InputGroupAddon>
                                    <Icon name="user" />
                                </InputGroupAddon>
                                <InputGroupInput id="username" autoComplete="username" placeholder="evil.rabbit" value="$profile.username" />
                                <InputGroupButton>Check</InputGroupButton>
                            </InputGroup>
                        </Field>
                    </Grid>
                    <Grid columns="2">
                        <Field>
                            <FieldLabel htmlFor="email">Email</FieldLabel>
                            <InputGroup>
                                <InputGroupAddon>
                                    <Icon name="mail" />
                                </InputGroupAddon>
                                <InputGroupInput id="email" autoComplete="email" placeholder="ada@longlink.dev" value="$profile.email" />
                                <InputGroupButton>Invite</InputGroupButton>
                            </InputGroup>
                        </Field>
                        <Field>
                            <FieldLabel htmlFor="team">Team</FieldLabel>
                            <Select value="$profile.team">
                                <SelectTrigger>
                                    <SelectValue placeholder="Select a team" />
                                </SelectTrigger>
                                <SelectContent>
                                    <SelectGroup>
                                        <SelectLabel>Teams</SelectLabel>
                                        <SelectItem value="ops">Operations</SelectItem>
                                        <SelectItem value="support">Support</SelectItem>
                                        <SelectItem value="product">Product</SelectItem>
                                    </SelectGroup>
                                </SelectContent>
                            </Select>
                        </Field>
                    </Grid>
                    <Grid columns="2">
                        <Field>
                            <FieldLabel htmlFor="password">Password</FieldLabel>
                            <Input id="password" type="password" autoComplete="new-password" placeholder="••••••••" value="$profile.password" />
                        </Field>
                        <Field>
                            <FieldLabel htmlFor="timezone">Timezone</FieldLabel>
                            <Select value="$profile.timezone">
                                <SelectTrigger>
                                    <SelectValue placeholder="Choose a timezone" />
                                </SelectTrigger>
                                <SelectContent>
                                    <SelectGroup>
                                        <SelectLabel>Regions</SelectLabel>
                                        <SelectItem value="utc">UTC</SelectItem>
                                        <SelectItem value="cet">CET</SelectItem>
                                        <SelectItem value="pst">PST</SelectItem>
                                    </SelectGroup>
                                </SelectContent>
                            </Select>
                        </Field>
                    </Grid>
                    <Field>
                        <FieldLabel htmlFor="notes">Notes</FieldLabel>
                        <Textarea id="notes" label="Notes" rows="4" value="$profile.notes" />
                        <FieldDescription>Keep the note short and clear.</FieldDescription>
                    </Field>
                    <FieldSet>
                        <FieldLegend>Preferences</FieldLegend>
                        <FieldDescription>These controls are designed to stay compact and readable.</FieldDescription>
                        <Grid columns="2">
                            <Field orientation="horizontal">
                                <Checkbox id="newsletter" checked="$profile.newsletter" />
                                <FieldLabel htmlFor="newsletter">Email digest</FieldLabel>
                            </Field>
                            <Field orientation="horizontal">
                                <Switch id="autosave" checked="$profile.autosave" size="sm" />
                                <FieldLabel htmlFor="autosave">Auto-save drafts</FieldLabel>
                            </Field>
                        </Grid>
                        <Field>
                            <FieldLabel>Priority</FieldLabel>
                            <RadioGroup name="priority" value="$profile.priority">
                                <RadioGroupItem value="low">Low</RadioGroupItem>
                                <RadioGroupItem value="medium">Medium</RadioGroupItem>
                                <RadioGroupItem value="high">High</RadioGroupItem>
                            </RadioGroup>
                        </Field>
                        <Field>
                            <FieldLabel>Workflow</FieldLabel>
                            <ButtonGroup>
                                <Button variant="outline">Draft</Button>
                                <Button variant="outline">Review</Button>
                                <Button variant="outline">Publish</Button>
                            </ButtonGroup>
                        </Field>
                    </FieldSet>
                    <Field>
                        <FieldLabel htmlFor="budget">Budget</FieldLabel>
                        <Slider id="budget" min="0" max="100" step="5" value="$budget" />
                        <FieldDescription>Set the allowed budget range.</FieldDescription>
                    </Field>
                    <Field>
                        <FieldLabel>Actions</FieldLabel>
                        <ButtonGroup>
                            <Action invalidate='["profile", "budget"]'>Cancel</Action>
                            <ButtonGroupSeparator />
                            <Action
                                action="/profiles/account"
                                json='${{ name: profile.name, username: profile.username, email: profile.email, team: profile.team, password: profile.password, timezone: profile.timezone, notes: profile.notes, newsletter: profile.newsletter, autosave: profile.autosave, priority: profile.priority, budget: budget.value }}'
                            >
                                Save profile
                            </Action>
                        </ButtonGroup>
                    </Field>
                </FieldGroup>
            </FieldSet>

            <Br />
            <Br />
            <Br />

            <FieldSet>
                <FieldLegend>More form chrome</FieldLegend>
                <FieldDescription>Extra field and control primitives used by the runtime.</FieldDescription>
                <FieldGroup>
                    <Field>
                        <FieldContent>
                            <FieldTitle>Email routing</FieldTitle>
                            <FieldDescription>Use a dedicated inbox for high-priority alerts.</FieldDescription>
                            <FieldSeparator>Validation</FieldSeparator>
                            <FieldError errors="${[{ message: 'Email routing is not configured yet' }]}" />
                        </FieldContent>
                    </Field>
                    <Field orientation="horizontal">
                        <Label htmlFor="digest-toggle">Daily digest</Label>
                        <Toggle id="digest-toggle" defaultPressed="true">On</Toggle>
                    </Field>
                    <Field>
                        <FieldLabel htmlFor="theme-mode">Theme mode</FieldLabel>
                        <ToggleGroup defaultValue="system">
                            <ToggleGroupItem value="system">System</ToggleGroupItem>
                            <ToggleGroupItem value="light">Light</ToggleGroupItem>
                            <ToggleGroupItem value="dark">Dark</ToggleGroupItem>
                        </ToggleGroup>
                    </Field>
                    <Field>
                        <FieldLabel htmlFor="region">Region</FieldLabel>
                        <Select defaultValue="us">
                            <SelectTrigger>
                                <SelectValue placeholder="Select a region" />
                            </SelectTrigger>
                            <SelectContent>
                                <SelectGroup>
                                    <SelectLabel>North America</SelectLabel>
                                    <SelectItem value="us">United States</SelectItem>
                                    <SelectItem value="ca">Canada</SelectItem>
                                </SelectGroup>
                                <SelectSeparator />
                                <SelectGroup>
                                    <SelectLabel>Europe</SelectLabel>
                                    <SelectItem value="uk">United Kingdom</SelectItem>
                                    <SelectItem value="de">Germany</SelectItem>
                                </SelectGroup>
                            </SelectContent>
                        </Select>
                    </Field>
                    <Field>
                        <FieldLabel htmlFor="endpoint">Endpoint</FieldLabel>
                        <InputGroup>
                            <InputGroupText>https://</InputGroupText>
                            <InputGroupInput id="endpoint" placeholder="api.longlink.dev" />
                            <InputGroupButton>Copy</InputGroupButton>
                        </InputGroup>
                    </Field>
                    <Field>
                        <FieldLabel>Actions</FieldLabel>
                        <ButtonGroup>
                            <Button variant="outline">Cancel</Button>
                            <ButtonGroupSeparator />
                            <Button>Save changes</Button>
                            <ButtonGroupText>Ctrl+S also works</ButtonGroupText>
                        </ButtonGroup>
                    </Field>
                </FieldGroup>
            </FieldSet>
        </TabsContent>
        <TabsContent value="item">
            <Hero icon="file-text">
                <HeroTitle>Invoice #INV-2048-0192</HeroTitle>
                <HeroDescription>Items, quantities, and totals for the current quote.</HeroDescription>
                <HeroContent>
                    <Button variant="outline" size="sm">
                        <Icon name="copy" />
                        Copy
                    </Button>
                </HeroContent>
            </Hero>
            <Columns>
                <Column width="75">
                    <Table>
                        <TableHeader>
                            <TableRow>
                                <TableHead>Item</TableHead>
                                <TableHead>Qty</TableHead>
                                <TableHead>Rate</TableHead>
                                <TableHead>Amount</TableHead>
                            </TableRow>
                        </TableHeader>
                        <TableBody>
                            <TableRow>
                                <TableCell>Discovery workshop</TableCell>
                                <TableCell>1</TableCell>
                                <TableCell>$1,200</TableCell>
                                <TableCell>$1,200</TableCell>
                            </TableRow>
                            <TableRow>
                                <TableCell>Implementation support</TableCell>
                                <TableCell>3</TableCell>
                                <TableCell>$900</TableCell>
                                <TableCell>$2,700</TableCell>
                            </TableRow>
                            <TableRow>
                                <TableCell>Review and revisions</TableCell>
                                <TableCell>2</TableCell>
                                <TableCell>$450</TableCell>
                                <TableCell>$900</TableCell>
                            </TableRow>
                        </TableBody>
                        <TableFooter>
                            <TableRow>
                                <TableCell>Total</TableCell>
                                <TableCell>6</TableCell>
                                <TableCell />
                                <TableCell>$4,800</TableCell>
                            </TableRow>
                        </TableFooter>
                    </Table>
                </Column>
                <Column width="25">
                    <Stack>
                        Actions for the current invoice and quote.
                        <Badge variant="outline">Pending approval</Badge>
                        <Divider />
                        <A href="/orders/new" active="hover"><Icon name="shopping-cart" /> Create order</A>
                        <A href="/invoices/new" active="hover"><Icon name="file-text" /> Create invoice</A>
                        <Dialog>
                            <DialogTrigger>
                                <A active="hover"><Icon name="pencil" /> Edit quote</A>
                            </DialogTrigger>
                            <DialogContent>
                                <DialogHeader>
                                    <DialogTitle>Edit quote</DialogTitle>
                                    <DialogDescription>Review the quote details before saving the next revision.</DialogDescription>
                                </DialogHeader>
                                <DialogFooter>
                                    <Button variant="outline">Cancel</Button>
                                    <Button>Save quote</Button>
                                </DialogFooter>
                            </DialogContent>
                        </Dialog>
                        <Divider />
                        <A href="/quotes/email" active="hover"><Icon name="mail" /> Email quote</A>
                        <Divider />
                        <A href="/actions" active="hover"><Icon name="layout-grid" /> More actions</A>
                        <Divider />
                        <Field orientation="horizontal">
                            <Avatar size="sm">
                                <AvatarImage src="/avatars/ada.png" alt="Ada Lovelace" />
                                <AvatarFallback>AL</AvatarFallback>
                            </Avatar>
                            Ada Lovelace
                        </Field>
                    </Stack>
                </Column>
            </Columns>
        </TabsContent>
        <TabsContent value="menu">
            <Menu defaultValue="overview">
                <MenuList>
                    <MenuSection value="overview">Overview</MenuSection>
                    <MenuSection value="settings">
                        Settings
                        <MenuSubSection value="profile">Profile</MenuSubSection>
                        <MenuSubSection value="billing">Billing</MenuSubSection>
                    </MenuSection>
                </MenuList>
                <MenuContent value="overview">
                    <P>Overview content for the active menu item.</P>
                </MenuContent>
                <MenuContent value="settings">
                    <P>Settings content for the active menu item.</P>
                </MenuContent>
                <MenuContent value="profile">
                    <P>Profile submenu content.</P>
                </MenuContent>
                <MenuContent value="billing">
                    <P>Billing submenu content.</P>
                </MenuContent>
            </Menu>
        </TabsContent>
        <TabsContent value="grid">
            <State id="gridSearch" value="" />
            <InputGroup>
                <InputGroupAddon>
                    <Icon name="search" />
                </InputGroupAddon>
                <InputGroupInput id="grid-search" value="$gridSearch.value" autoComplete="off" placeholder="Search cards, alerts, and revenue" />
                <InputGroupButton>
                    Search
                    <Icon name="arrow-right" />
                </InputGroupButton>
            </InputGroup>
            <Columns>
                <Column width="75">
                    <Grid columns="2">
                        <Card if="${gridSearch.value in 'Revenue overview'}">
                            <CardHeader>
                                <CardTitle>Revenue overview</CardTitle>
                                <CardDescription>Weekly performance snapshot</CardDescription>
                                <CardAction>
                                    <A href="/reports/revenue" variant="outline">Open report</A>
                                </CardAction>
                            </CardHeader>
                            <CardContent>
                                <P>Revenue is trending up, with 88% of the weekly target already complete.</P>
                            </CardContent>
                            <CardFooter>
                                <Badge variant="outline">On track</Badge>
                            </CardFooter>
                        </Card>
                        <Card if="${gridSearch.value in 'Usage'}">
                            <CardHeader>
                                <CardTitle>Usage</CardTitle>
                                <CardDescription>Active sessions</CardDescription>
                            </CardHeader>
                            <CardContent>
                                <P>Traffic increased by 14% over the last seven days.</P>
                            </CardContent>
                            <CardFooter>
                                <P>Updated 12 minutes ago.</P>
                            </CardFooter>
                        </Card>
                        <Card if="${gridSearch.value in 'Pipeline'}">
                            <CardHeader>
                                <CardTitle>Pipeline</CardTitle>
                                <CardDescription>Open work</CardDescription>
                            </CardHeader>
                            <CardContent>
                                <P>Three items are blocked and awaiting review.</P>
                            </CardContent>
                            <CardFooter>
                                <Badge variant="outline">3 open</Badge>
                            </CardFooter>
                        </Card>
                        <Card if="${gridSearch.value in 'Alerts'}">
                            <CardHeader>
                                <CardTitle>Alerts</CardTitle>
                                <CardDescription>Recent signals</CardDescription>
                            </CardHeader>
                            <CardContent>
                                <P>Two new notifications were raised this morning.</P>
                            </CardContent>
                            <CardFooter>
                                <Button variant="outline">Review alerts</Button>
                            </CardFooter>
                        </Card>
                    </Grid>
                </Column>
                <Column width="25">
                    <Stack>
                        <P>Quick links in the same style as a GitHub repo sidebar.</P>
                        <A href="/code" active="hover"><Icon name="code-2" /> Code</A>
                        <A href="/issues" active="hover"><Icon name="circle-alert" /> Issues</A>
                        <A href="/pulls" active="hover"><Icon name="git-pull-request" /> Pull requests</A>
                        <A href="/actions" active="hover"><Icon name="play-circle" /> Actions</A>
                        <A href="/projects" active="hover"><Icon name="layout-grid" /> Projects</A>
                        <A href="/security" active="hover"><Icon name="shield" /> Security</A>
                        <A href="/insights" active="hover"><Icon name="chart-column" /> Insights</A>
                    </Stack>
                </Column>
            </Columns>
        </TabsContent>
    </Tabs>
</longlink>
