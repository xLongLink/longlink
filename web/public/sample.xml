<?xml-model href="https://docs.longlink.dev/schema.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<longlink>
    <Tabs defaultValue="text">
        <TabsList variant="line">
            <TabsTrigger value="text">Text</TabsTrigger>
            <TabsTrigger value="form">Form</TabsTrigger>
            <TabsTrigger value="item">Item</TabsTrigger>
            <TabsTrigger value="grid">Grid</TabsTrigger>
            <TabsTrigger value="other">Other</TabsTrigger>
        </TabsList>

        <TabsContent value="text">
            <br />

            <h1>Basic Html Elements are Supported</h1>
            <p>The import pipeline is now stable. We finished the retry fix for <code>customer_sync</code>,
                and the nightly run completed without manual intervention.</p>
            <h2>What changed</h2>
            <p>The team tightened validation on <b>customer IDs</b>, removed one <s>temporary bypass</s>,
                and kept the rollout limited to the staging workspace. The result is a cleaner path
                from source data to <u>dashboard output</u>.</p>
            <h3>Today’s checklist</h3>
            <ul>
                <li>Confirm the summary totals match the warehouse export.</li>
                <li>Review any records marked with H<sub>2</sub>O-style test labels.</li>
                <li>Watch the next deploy window at 10<sup>30</sup> for regressions.</li>
            </ul>
            <h3>Follow-up steps</h3>
            <ol>
                <li>Share the digest with ops and support.</li>
                <li>Validate the next sync against the staging workspace.</li>
                <li>Close the ticket after the report refreshes.</li>
            </ol>
            <h4>Notes</h4>
            <p>For the deeper walkthrough, open <a href="/icons">the icon catalog</a> or inspect the
                generated report after the next sync.</p>
        </TabsContent>

        <TabsContent value="form">
            <FieldSet>
                <FieldLegend>Profile</FieldLegend>
                <FieldDescription>All form controls are grouped here.</FieldDescription>
                <FieldGroup>
                    <Field>
                        <FieldContent>
                            <FieldTitle>Full name</FieldTitle>
                            <FieldDescription>This appears on invoices and emails.</FieldDescription>
                        </FieldContent>
                        <FieldLabel htmlFor="name">Full name</FieldLabel>
                        <Input id="name" autoComplete="off" placeholder="Evil Rabbit" />
                    </Field>
                    <Field>
                        <FieldLabel htmlFor="username">Username</FieldLabel>
                        <Input id="username" autoComplete="off" aria-invalid="true" />
                        <FieldError>Choose another username.</FieldError>
                    </Field>
                    <Field>
                        <FieldLabel htmlFor="notes">Notes</FieldLabel>
                        <Textarea id="notes" label="Notes" rows="4" value="Draft notes" />
                    </Field>
                    <Field orientation="horizontal">
                        <Checkbox id="newsletter" defaultChecked="true" />
                        <FieldLabel htmlFor="newsletter">Newsletter</FieldLabel>
                    </Field>
                    <Field orientation="horizontal">
                        <Switch id="marketing" defaultChecked="false" size="sm" />
                        <FieldLabel htmlFor="marketing">Marketing updates</FieldLabel>
                    </Field>
                    <Field>
                        <FieldLabel htmlFor="notifications">Notifications</FieldLabel>
                        <Toggle id="notifications" defaultPressed="true" size="sm" variant="outline">
                            Notifications</Toggle>
                    </Field>
                    <Field>
                        <FieldLabel htmlFor="volume">Priority</FieldLabel>
                        <Slider id="volume" defaultValue="${[35]}" min="0" max="100" step="5" />
                    </Field>
                    <Field>
                        <FieldLabel htmlFor="range">Range</FieldLabel>
                        <Slider id="range" defaultValue="${[25, 75]}" min="0" max="100" step="5" />
                    </Field>
                    <Field>
                        <FieldLabel>View mode</FieldLabel>
                        <ToggleGroup type="single">
                            <ToggleGroupItem value="a">A</ToggleGroupItem>
                            <ToggleGroupItem value="b">B</ToggleGroupItem>
                            <ToggleGroupItem value="c">C</ToggleGroupItem>
                        </ToggleGroup>
                    </Field>
                    <FieldSet>
                        <FieldLegend>Priority</FieldLegend>
                        <FieldDescription>Choose one level for this item.</FieldDescription>
                        <FieldGroup>
                            <RadioGroup name="priority" defaultValue="medium">
                                <RadioGroupItem value="low">Low</RadioGroupItem>
                                <RadioGroupItem value="medium">Medium</RadioGroupItem>
                                <RadioGroupItem value="high">High</RadioGroupItem>
                            </RadioGroup>
                        </FieldGroup>
                    </FieldSet>
                    <Field>
                        <FieldLabel htmlFor="view">Select</FieldLabel>
                        <Select defaultValue="overview">
                            <SelectTrigger>
                                <SelectValue />
                            </SelectTrigger>
                            <SelectContent>
                                <SelectGroup>
                                    <SelectLabel>Views</SelectLabel>
                                    <SelectItem value="overview">Overview</SelectItem>
                                    <SelectItem value="settings">Settings</SelectItem>
                                </SelectGroup>
                                <SelectSeparator />
                                <SelectGroup>
                                    <SelectLabel>Status</SelectLabel>
                                    <SelectItem value="active">Active</SelectItem>
                                    <SelectItem value="archived">Archived</SelectItem>
                                </SelectGroup>
                            </SelectContent>
                        </Select>
                    </Field>
                    <FieldSeparator>or</FieldSeparator>
                    <Field orientation="horizontal">
                        <Button variant="outline">Cancel</Button>
                        <Button submit="true">Save</Button>
                    </Field>
                </FieldGroup>
            </FieldSet>
        </TabsContent>

        <TabsContent value="item">
            <Columns>
                <Column width="70">
                    <FieldSet>
                        <FieldLegend>Invoice</FieldLegend>
                        <FieldDescription>Items, quantities, and totals for the current quote.</FieldDescription>
                        <Table>
                            <TableHeader>
                                <TableRow>
                                    <TableHead>Item</TableHead>
                                    <TableHead>Qty</TableHead>
                                    <TableHead>Rate</TableHead>
                                    <TableHead>Amount</TableHead>
                                </TableRow>
                            </TableHeader>
                            <TableBody>
                                <TableRow>
                                    <TableCell>Discovery workshop</TableCell>
                                    <TableCell>1</TableCell>
                                    <TableCell>$1,200</TableCell>
                                    <TableCell>$1,200</TableCell>
                                </TableRow>
                                <TableRow>
                                    <TableCell>Implementation support</TableCell>
                                    <TableCell>3</TableCell>
                                    <TableCell>$900</TableCell>
                                    <TableCell>$2,700</TableCell>
                                </TableRow>
                                <TableRow>
                                    <TableCell>Review and revisions</TableCell>
                                    <TableCell>2</TableCell>
                                    <TableCell>$450</TableCell>
                                    <TableCell>$900</TableCell>
                                </TableRow>
                            </TableBody>
                            <TableFooter>
                                <TableRow>
                                    <TableCell>Total</TableCell>
                                    <TableCell>6</TableCell>
                                    <TableCell />
                                    <TableCell>$4,800</TableCell>
                                </TableRow>
                            </TableFooter>
                        </Table>
                    </FieldSet>
                </Column>
                <Column width="30">
                    <FieldSet>
                        <FieldLegend>Status</FieldLegend>
                        <FieldDescription>Actions for the current invoice and quote.</FieldDescription>
                        <FieldGroup>
                            <Badge variant="outline">Pending approval</Badge>
                            <Divider />
                            <a href="/orders/new">
                                <Icon name="shopping-cart" /> Create order
                            </a>
                            <a href="/invoices/new">
                                <Icon name="file-text" /> Create invoice
                            </a>
                            <a href="/quotes/edit">
                                <Icon name="pencil" /> Edit quote
                            </a>
                            <Divider />
                            <a href="/quotes/email">
                                <Icon name="mail" /> Email quote
                            </a>
                            <Divider />
                            <a href="/actions">
                                <Icon name="layout-grid" /> More actions
                            </a>
                        </FieldGroup>
                    </FieldSet>
                    
                    <Divider />
                    
                    <FieldSet>
                        <Field orientation="horizontal">
                            <Avatar size="sm">
                                <AvatarImage src="/avatars/ada.png" alt="Ada Lovelace" />
                                <AvatarFallback>AL</AvatarFallback>
                            </Avatar>
                            <FieldTitle>Ada Lovelace</FieldTitle>
                        </Field>
                    </FieldSet>
                </Column>
            </Columns>
        </TabsContent>

        <TabsContent value="grid">
            <InputGroup>
                <InputGroupAddon>
                    <Icon name="search" />
                </InputGroupAddon>
                <InputGroupInput
                    id="grid-search"
                    autoComplete="off"
                    placeholder="Search cards, alerts, and revenue"
                />
                <InputGroupButton>
                    Search <Icon name="arrow-right" />
                </InputGroupButton>
            </InputGroup>

            <Columns>
                <Column width="70">
                    <Grid columns="2">
                        <Card>
                            <CardHeader>
                                <CardTitle>Revenue overview</CardTitle>
                                <CardDescription>Weekly performance snapshot</CardDescription>
                                <CardAction>
                                    <Button action="/reports/revenue" method="GET" variant="outline">Open
                                        report</Button>
                                </CardAction>
                            </CardHeader>
                            <CardContent>
                                <p>Revenue is trending up, with 88% of the weekly target already
                                    complete.</p>
                            </CardContent>
                            <CardFooter>
                                <Badge variant="outline">On track</Badge>
                            </CardFooter>
                        </Card>
                        <Card>
                            <CardHeader>
                                <CardTitle>Usage</CardTitle>
                                <CardDescription>Active sessions</CardDescription>
                            </CardHeader>
                            <CardContent>
                                <p>Traffic increased by 14% over the last seven days.</p>
                            </CardContent>
                            <CardFooter>
                                <p>Updated 12 minutes ago.</p>
                            </CardFooter>
                        </Card>
                        <Card>
                            <CardHeader>
                                <CardTitle>Pipeline</CardTitle>
                                <CardDescription>Open work</CardDescription>
                            </CardHeader>
                            <CardContent>
                                <p>Three items are blocked and awaiting review.</p>
                            </CardContent>
                            <CardFooter>
                                <Badge variant="outline">3 open</Badge>
                            </CardFooter>
                        </Card>
                        <Card>
                            <CardHeader>
                                <CardTitle>Alerts</CardTitle>
                                <CardDescription>Recent signals</CardDescription>
                            </CardHeader>
                            <CardContent>
                                <p>Two new notifications were raised this morning.</p>
                            </CardContent>
                            <CardFooter>
                                <Button variant="outline">Review alerts</Button>
                            </CardFooter>
                        </Card>
                    </Grid>
                </Column>
                <Column width="30">
                    <FieldSet>
                        <FieldLegend>Repository</FieldLegend>
                        <FieldDescription>Quick links in the same style as a GitHub repo sidebar.</FieldDescription>
                        <FieldGroup>
                            <a href="/code">
                                <Icon name="code-2" /> Code </a>
                            <a href="/issues">
                                <Icon name="circle-alert" /> Issues </a>
                            <a href="/pulls">
                                <Icon name="git-pull-request" /> Pull requests </a>
                            <a href="/actions">
                                <Icon name="play-circle" /> Actions </a>
                            <a href="/projects">
                                <Icon name="layout-grid" /> Projects </a>
                            <a href="/security">
                                <Icon name="shield" /> Security </a>
                            <a href="/insights">
                                <Icon name="chart-column" /> Insights </a>
                        </FieldGroup>
                    </FieldSet>
                </Column>
            </Columns>
        </TabsContent>

        <TabsContent value="other">
            <Hero icon="sparkles">
                <HeroTitle>Other components</HeroTitle>
                <HeroDescription>Layout, media, feedback, and data display components live here.</HeroDescription>
                <HeroContent>
                    <Dialog>
                        <DialogTrigger>
                            <Button variant="outline">Open dialog</Button>
                        </DialogTrigger>
                        <DialogContent>
                            <DialogHeader>
                                <DialogTitle>Delete issue</DialogTitle>
                                <DialogDescription>This cannot be undone.</DialogDescription>
                            </DialogHeader>
                            <DialogFooter>
                                <Button variant="outline">Cancel</Button>
                                <Button>Delete</Button>
                            </DialogFooter>
                        </DialogContent>
                    </Dialog>
                </HeroContent>
            </Hero>

            <AvatarGroup>
                <Avatar size="sm">
                    <AvatarImage src="/avatars/ada.png" alt="Ada Lovelace" />
                    <AvatarFallback>AL</AvatarFallback>
                    <AvatarBadge>1</AvatarBadge>
                </Avatar>
                <Avatar>
                    <AvatarImage src="/avatars/grace.png" alt="Grace Hopper" />
                    <AvatarFallback>GH</AvatarFallback>
                </Avatar>
                <AvatarGroupCount>+2</AvatarGroupCount>
            </AvatarGroup>

            <TooltipProvider>
                <Tooltip>
                    <TooltipTrigger>Hover tooltip</TooltipTrigger>
                    <TooltipContent side="top">Tooltip text</TooltipContent>
                </Tooltip>
            </TooltipProvider>

            <ButtonGroup>
                <Button variant="outline">Cancel</Button>
                <Input placeholder="Search" value="Quick search" />
                <Button>Search</Button>
            </ButtonGroup>

            <ButtonGroup>
                <Button>Save</Button>
                <ButtonGroupSeparator />
                <ButtonGroupText>Quick actions</ButtonGroupText>
            </ButtonGroup>
        </TabsContent>
    </Tabs>
</longlink>
