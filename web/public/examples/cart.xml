<longlink>
    <State
        id="cart"
        value='[]'
    />
    <State id="search" value='""' />

    <Hero icon="shopping-cart">
        <HeroTitle>Fruit cart</HeroTitle>
        <HeroDescription>Browse fresh fruit cards, add items to the cart, and review the order summary.</HeroDescription>
    </Hero>

    <Columns>
        <Column width="75">
            <InputGroup>
                <InputGroupAddon>
                    <Icon name="search" />
                </InputGroupAddon>
                <InputGroupInput value="$search.value" placeholder="Search fruit" />
            </InputGroup>

            <Grid columns="2">
                <Card if='${search.value in "Apples apples crisp and sweet orchard fruit"}'>
                    <CardHeader>
                        <CardTitle>Apples</CardTitle>
                        <CardDescription>Crisp and sweet orchard fruit</CardDescription>
                        <CardAction>
                            <Badge variant="outline">$2.40</Badge>
                        </CardAction>
                    </CardHeader>
                    <CardContent>
                        <P>Bright red apples with a clean finish for snacks, salads, and lunch boxes.</P>
                    </CardContent>
                    <CardFooter className="justify-end">
                        <Button variant="outline" size="xs" append="cart" item='${{ name: "Apples", quantity: 1, price: "$2.40" }}'>
                            Add to cart
                        </Button>
                    </CardFooter>
                </Card>

                <Card if='${search.value in "Bananas bananas soft sweet and easy to pack"}'>
                    <CardHeader>
                        <CardTitle>Bananas</CardTitle>
                        <CardDescription>Soft, sweet, and easy to pack</CardDescription>
                        <CardAction>
                            <Badge variant="outline">$1.10</Badge>
                        </CardAction>
                    </CardHeader>
                    <CardContent>
                        <P>Great for breakfast, smoothies, and quick energy on the go.</P>
                    </CardContent>
                    <CardFooter className="justify-end">
                        <Button variant="outline" size="xs" append="cart" item='${{ name: "Bananas", quantity: 1, price: "$1.10" }}'>
                            Add to cart
                        </Button>
                    </CardFooter>
                </Card>

                <Card if='${search.value in "Strawberries strawberries small berries for fresh desserts"}'>
                    <CardHeader>
                        <CardTitle>Strawberries</CardTitle>
                        <CardDescription>Small berries for fresh desserts</CardDescription>
                        <CardAction>
                            <Badge variant="outline">$4.50</Badge>
                        </CardAction>
                    </CardHeader>
                    <CardContent>
                        <P>Juicy berries that work well with yogurt, cream, and pastries.</P>
                    </CardContent>
                    <CardFooter className="justify-end">
                        <Button variant="outline" size="xs" append="cart" item='${{ name: "Strawberries", quantity: 1, price: "$4.50" }}'>
                            Add to cart
                        </Button>
                    </CardFooter>
                </Card>

                <Card if='${search.value in "Pears pears soft texture with a mellow finish"}'>
                    <CardHeader>
                        <CardTitle>Pears</CardTitle>
                        <CardDescription>Soft texture with a mellow finish</CardDescription>
                        <CardAction>
                            <Badge variant="outline">$3.20</Badge>
                        </CardAction>
                    </CardHeader>
                    <CardContent>
                        <P>Ideal for a calm dessert plate or a simple afternoon snack.</P>
                    </CardContent>
                    <CardFooter className="justify-end">
                        <Button variant="outline" size="xs" append="cart" item='${{ name: "Pears", quantity: 1, price: "$3.20" }}'>
                            Add to cart
                        </Button>
                    </CardFooter>
                </Card>
            </Grid>
        </Column>

        <Column width="25">
            <Stack>
                <P>Cart</P>
                <Divider />
                <P if="${cart.value.length in [0]}">Cart is empty</P>
                <Ul if="${cart.value.length}">
                    <For each="${cart.value}" as="item">
                        <Li>${item.name} · Qty: ${item.quantity} · ${item.price}</Li>
                    </For>
                </Ul>
                <Divider />
                <Button>Order</Button>
            </Stack>
        </Column>
    </Columns>
</longlink>
