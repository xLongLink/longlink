<longlink>
    <State
        id="cart"
        value='[{ name: "Apples", quantity: 2, price: "$4.80" }, { name: "Bananas", quantity: 1, price: "$1.10" }, { name: "Strawberries", quantity: 1, price: "$4.50" }]'
    />

    <Hero icon="shopping-cart">
        <HeroTitle>Fruit cart</HeroTitle>
        <HeroDescription>Browse fresh fruit cards, add items to the cart, and review the order summary.</HeroDescription>
    </Hero>

    <Columns>
        <Column width="75">
            <Grid columns="2">
                <Card>
                    <CardHeader>
                        <CardTitle>Apples</CardTitle>
                        <CardDescription>Crisp and sweet orchard fruit</CardDescription>
                        <CardAction>
                            <Badge variant="outline">$2.40</Badge>
                        </CardAction>
                    </CardHeader>
                    <CardContent>
                        <P>Bright red apples with a clean finish for snacks, salads, and lunch boxes.</P>
                    </CardContent>
                    <CardFooter className="justify-end">
                        <Button variant="outline" size="xs">
                            Add to cart
                        </Button>
                    </CardFooter>
                </Card>

                <Card>
                    <CardHeader>
                        <CardTitle>Bananas</CardTitle>
                        <CardDescription>Soft, sweet, and easy to pack</CardDescription>
                        <CardAction>
                            <Badge variant="outline">$1.10</Badge>
                        </CardAction>
                    </CardHeader>
                    <CardContent>
                        <P>Great for breakfast, smoothies, and quick energy on the go.</P>
                    </CardContent>
                    <CardFooter className="justify-end">
                        <Button variant="outline" size="xs">
                            Add to cart
                        </Button>
                    </CardFooter>
                </Card>

                <Card>
                    <CardHeader>
                        <CardTitle>Strawberries</CardTitle>
                        <CardDescription>Small berries for fresh desserts</CardDescription>
                        <CardAction>
                            <Badge variant="outline">$4.50</Badge>
                        </CardAction>
                    </CardHeader>
                    <CardContent>
                        <P>Juicy berries that work well with yogurt, cream, and pastries.</P>
                    </CardContent>
                    <CardFooter className="justify-end">
                        <Button variant="outline" size="xs">
                            Add to cart
                        </Button>
                    </CardFooter>
                </Card>

                <Card>
                    <CardHeader>
                        <CardTitle>Pears</CardTitle>
                        <CardDescription>Soft texture with a mellow finish</CardDescription>
                        <CardAction>
                            <Badge variant="outline">$3.20</Badge>
                        </CardAction>
                    </CardHeader>
                    <CardContent>
                        <P>Ideal for a calm dessert plate or a simple afternoon snack.</P>
                    </CardContent>
                    <CardFooter className="justify-end">
                        <Button variant="outline" size="xs">
                            Add to cart
                        </Button>
                    </CardFooter>
                </Card>
            </Grid>
        </Column>

        <Column width="25">
            <Stack>
                <P>Cart</P>
                <Divider />
                <For each="$cart.value" as="item">
                    <Card>
                        <CardHeader>
                            <CardTitle>${item.name}</CardTitle>
                            <CardDescription>Qty: ${item.quantity}</CardDescription>
                        </CardHeader>
                        <CardContent>
                            <P>Selected fruit for checkout.</P>
                        </CardContent>
                        <CardFooter>
                            <Badge variant="outline">${item.price}</Badge>
                        </CardFooter>
                    </Card>
                </For>
                <Divider />
                <Button>Order</Button>
            </Stack>
        </Column>
    </Columns>
</longlink>
