<longlink>
    <Hero icon="file-text">
        <HeroTitle>Quote #Q-2048-0192</HeroTitle>
        <HeroDescription>Items, conditions, address, texts, and settings for the current quote.</HeroDescription>
        <HeroAction>
            <Button variant="outline" size="sm">
                <Icon name="copy" />
                Copy quote
            </Button>
        </HeroAction>
    </Hero>

    <Columns>
        <Column width="75">
            <Tabs defaultValue="items">
                <Tab value="items" label="Items">
                    <Table>
                        <Thead>
                            <Tr>
                                <Th>Item</Th>
                                <Th>Qty</Th>
                                <Th>Rate</Th>
                                <Th>Amount</Th>
                            </Tr>
                        </Thead>
                        <Tbody>
                            <Tr>
                                <Td>Discovery workshop</Td>
                                <Td>1</Td>
                                <Td>$1,200</Td>
                                <Td>$1,200</Td>
                            </Tr>
                            <Tr>
                                <Td>Implementation support</Td>
                                <Td>3</Td>
                                <Td>$900</Td>
                                <Td>$2,700</Td>
                            </Tr>
                            <Tr>
                                <Td>Review and revisions</Td>
                                <Td>2</Td>
                                <Td>$450</Td>
                                <Td>$900</Td>
                            </Tr>
                        </Tbody>
                        <Tfoot>
                            <Tr>
                                <Td>Total</Td>
                                <Td>6</Td>
                                <Td />
                                <Td>$4,800</Td>
                            </Tr>
                        </Tfoot>
                    </Table>
                </Tab>

                <Tab value="conditions" label="Conditions">
                    <Stack>
                        <Badge variant="outline">Pending approval</Badge>
                        <P>Net 30 payment terms apply after the final revision is accepted.</P>
                        <Ul>
                            <Li>Pricing is valid for 14 days.</Li>
                            <Li>Work begins after deposit confirmation.</Li>
                            <Li>Scope changes are quoted separately.</Li>
                        </Ul>
                    </Stack>
                </Tab>

                <Tab value="address" label="Address">
                    <Stack>
                        <H3>Billing address</H3>
                        <P>Where the quote should be sent and billed.</P>
                        <Field>
                            <FieldLabel htmlFor="company">Company</FieldLabel>
                            <Input id="company" value="Ada Labs" />
                        </Field>
                        <Field>
                            <FieldLabel htmlFor="street">Street</FieldLabel>
                            <Input id="street" value="123 Longlink Ave" />
                        </Field>
                        <Grid columns="2">
                            <Field>
                                <FieldLabel htmlFor="city">City</FieldLabel>
                                <Input id="city" value="Berlin" />
                            </Field>
                            <Field>
                                <FieldLabel htmlFor="postal">Postal code</FieldLabel>
                                <Input id="postal" value="10115" />
                            </Field>
                        </Grid>
                    </Stack>
                </Tab>

                <Tab value="texts" label="Texts">
                    <Stack>
                        <Card>
                            <CardContent>
                                <Stack>
                                    <CardTitle>Intro text</CardTitle>
                                    <CardDescription>Shown at the top of the quote email.</CardDescription>
                                    <Textarea rows="4" value="Thanks for reviewing the quote. The summary below reflects the current scope and pricing." />
                                </Stack>
                            </CardContent>
                        </Card>
                        <Card>
                            <CardContent>
                                <Stack>
                                    <CardTitle>Footer text</CardTitle>
                                    <CardDescription>Used for the approval reminder.</CardDescription>
                                    <Textarea rows="3" value="Reply with approval or change requests before the end of the week." />
                                </Stack>
                            </CardContent>
                        </Card>
                    </Stack>
                </Tab>

                <Tab value="settings" label="Settings">
                    <Stack>
                        <H3>Quote settings</H3>
                        <P>Configure how the quote behaves for the current workflow.</P>
                        <Grid columns="2">
                            <Field orientation="horizontal">
                                <Switch id="tax" defaultChecked="true" />
                                <FieldLabel htmlFor="tax">Include tax</FieldLabel>
                            </Field>
                            <Field orientation="horizontal">
                                <Switch id="discount" defaultChecked="false" />
                                <FieldLabel htmlFor="discount">Allow discount</FieldLabel>
                            </Field>
                        </Grid>
                        <Field>
                            <FieldLabel>Quote status</FieldLabel>
                            <RadioGroup name="status" defaultValue="draft">
                                <RadioGroupItem value="draft">Draft</RadioGroupItem>
                                <RadioGroupItem value="sent">Sent</RadioGroupItem>
                                <RadioGroupItem value="approved">Approved</RadioGroupItem>
                            </RadioGroup>
                        </Field>
                    </Stack>
                </Tab>
            </Tabs>
        </Column>

        <Column width="25">
            <Stack>
                <P>Quick actions for the current quote.</P>
                <A href="/quotes/send" active="hover">
                    <Icon name="mail" /> Send quote
                </A>
                <A href="/quotes/pdf" active="hover">
                    <Icon name="download" /> Download PDF
                </A>
                <A href="/quotes/duplicate" active="hover">
                    <Icon name="copy" /> Duplicate
                </A>
                <Divider />
                <Badge variant="outline">Awaiting client review</Badge>
            </Stack>
        </Column>
    </Columns>
</longlink>
