{
    "name": "web",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "typecheck": "tsc -b",
        "build:api": "tsc -b && vite build --mode api && bun scripts/prerender-public-pages.ts",
        "build:api:bundle": "vite build --mode api && bun scripts/prerender-public-pages.ts",
        "build:sdk": "tsc -b && vite build --mode sdk",
        "build:sdk:bundle": "vite build --mode sdk",
        "lint": "eslint . --fix",
        "preview": "vite preview",
        "format": "bunx prettier . --write",
        "dev": "vite",
        "test": "bun test tests/xml"
    },
    "dependencies": {
        "@base-ui/react": "^1.6.0",
        "@fontsource-variable/inter": "^5.2.8",
        "@hookform/resolvers": "^5.4.0",
        "@tailwindcss/vite": "^4.3.2",
        "@tanstack/react-query": "^5.101.2",
        "@tanstack/react-table": "^8.21.3",
        "acorn": "^8.17.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "embla-carousel-react": "^8.6.0",
        "fast-xml-parser": "^5.9.3",
        "i18next": "^26.3.4",
        "input-otp": "^1.4.2",
        "lodash": "^4.18.1",
        "lucide-react": "^0.563.0",
        "react": "^19.2.7",
        "react-day-picker": "^10.0.1",
        "react-dom": "^19.2.7",
        "react-hook-form": "^7.81.0",
        "react-i18next": "^17.0.8",
        "react-resizable-panels": "^4.12.1",
        "react-router": "^8.2.0",
        "react-syntax-highlighter": "^16.1.1",
        "recharts": "3.8.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.2",
        "tw-animate-css": "^1.4.0",
        "ufo": "^1.6.4",
        "valtio": "^2.3.2",
        "vaul": "^1.1.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@happy-dom/global-registrator": "^20.10.6",
        "@types/bun": "^1.3.14",
        "@types/lodash": "^4.17.24",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/react-syntax-highlighter": "^15.5.13",
        "@vitejs/plugin-react": "^6.0.3",
        "eslint": "^9.39.4",
        "eslint-plugin-perfectionist": "^5.10.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.4.26",
        "globals": "^17.7.0",
        "prettier": "3.9.4",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.63.0",
        "vite": "^8.1.3"
    },
    "overrides": {
        "@babel/core": "7.29.7",
        "brace-expansion": "5.0.7",
        "flatted": "3.4.2",
        "js-yaml": "4.3.0"
    },
    "prettier": {
        "semi": true,
        "singleQuote": true,
        "printWidth": 120,
        "tabWidth": 4,
        "trailingComma": "es5",
        "arrowParens": "always"
    }
