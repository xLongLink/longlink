{
    "name": "web",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "astryx": "node node_modules/@astryxdesign/cli/bin/astryx.mjs",
        "theme:build": "bun run astryx theme build src/lib/default-theme.ts --out src/lib/generated/longlink-neutral-default.css",
        "typecheck": "tsc -b",
        "build:api": "tsc -b && vite build --mode api && bun scripts/prerender-public-pages.ts",
        "build:api:bundle": "vite build --mode api && bun scripts/prerender-public-pages.ts",
        "build:sdk": "tsc -b && vite build --mode sdk",
        "build:sdk:bundle": "vite build --mode sdk",
        "lint": "eslint . --fix",
        "preview": "vite preview",
        "format": "bunx prettier . --write",
        "dev": "vite",
        "test": "bun test tests/xml"
    },
    "dependencies": {
        "@astryxdesign/core": "0.1.7",
        "@astryxdesign/theme-neutral": "0.1.7",
        "@fontsource-variable/inter": "^5.2.8",
        "@hookform/resolvers": "^5.4.0",
        "@stylexjs/stylex": "0.19.0",
        "@tailwindcss/vite": "^4.3.2",
        "@tanstack/react-query": "^5.101.2",
        "acorn": "^8.17.0",
        "fast-xml-parser": "^5.10.0",
        "lodash": "^4.18.1",
        "lucide-react": "^0.563.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-hook-form": "^7.81.0",
        "react-router": "^8.2.0",
        "tailwindcss": "^4.3.2",
        "ufo": "^1.6.4",
        "valtio": "^2.3.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@astryxdesign/cli": "0.1.7",
        "@eslint/js": "^9.39.4",
        "@happy-dom/global-registrator": "^20.10.6",
        "@types/bun": "^1.3.14",
        "@types/lodash": "^4.17.24",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "eslint": "^9.39.4",
        "eslint-plugin-perfectionist": "^5.10.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.4.26",
        "globals": "^17.7.0",
        "prettier": "3.9.5",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.63.0",
        "vite": "^8.1.3"
    },
    "overrides": {
        "@babel/core": "7.29.7",
        "brace-expansion": "5.0.7",
        "flatted": "3.4.2",
        "js-yaml": "4.3.0"
    },
    "prettier": {
        "semi": true,
        "singleQuote": true,
        "printWidth": 120,
        "tabWidth": 4,
        "trailingComma": "es5",
        "arrowParens": "always"
    },
    "astryx": {
        "theme": "@astryxdesign/theme-neutral"
    }
}
