  <xsd:complexType name="HeroType" mixed="true">
    <xsd:sequence>
      <xsd:choice minOccurs="0" maxOccurs="unbounded">
        <xsd:any processContents="lax" />
      </xsd:choice>
    </xsd:sequence>
    <xsd:attribute name="title" type="xsd:string" use="required" />
    <xsd:attribute name="subtitle" type="xsd:string" use="optional" />
    <xsd:attribute name="icon" type="xsd:string" use="optional" />
  </xsd:complexType>
  <xsd:element name="Hero" type="HeroType" />
  
  <xsd:complexType name="MenuType" mixed="true"><xsd:complexContent><xsd:extension base="ChildrenOnlyType" /></xsd:complexContent></xsd:complexType>
  <xsd:element name="Menu" type="MenuType" />
  
  <xsd:complexType name="MenuSectionType" mixed="true"><xsd:complexContent><xsd:extension base="ChildrenOnlyType"><xsd:attribute name="title" type="xsd:string" use="optional" /><xsd:attribute name="icon" type="xsd:string" use="optional" /></xsd:extension></xsd:complexContent></xsd:complexType>
  <xsd:element name="MenuSection" type="MenuSectionType" />
  
  <xsd:complexType name="MenuSubSectionType" mixed="true"><xsd:complexContent><xsd:extension base="ChildrenOnlyType"><xsd:attribute name="title" type="xsd:string" use="optional" /><xsd:attribute name="root" type="xsd:boolean" use="optional" /></xsd:extension></xsd:complexContent></xsd:complexType>
