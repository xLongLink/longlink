          <xsd:simpleType>
            <xsd:restriction base="xsd:string">
              <xsd:enumeration value="xs" />
              <xsd:enumeration value="sm" />
              <xsd:enumeration value="icon-xs" />
              <xsd:enumeration value="icon-sm" />
            </xsd:restriction>
          </xsd:simpleType>
        </xsd:attribute>
        <xsd:attribute name="type" use="optional" default="button">
          <xsd:simpleType>
            <xsd:restriction base="xsd:string">
              <xsd:enumeration value="button" />
              <xsd:enumeration value="submit" />
