  <xsd:element name="CardFooter" type="CardFooterType" />
  
  <xsd:complexType name="CardHeaderType" mixed="true"><xsd:complexContent><xsd:extension base="ChildrenOnlyType" /></xsd:complexContent></xsd:complexType>
  <xsd:element name="CardHeader" type="CardHeaderType" />
  
  <xsd:complexType name="CardTitleType" mixed="true"><xsd:complexContent><xsd:extension base="ChildrenOnlyType" /></xsd:complexContent></xsd:complexType>
  <xsd:element name="CardTitle" type="CardTitleType" />
  
  <xsd:complexType name="ColumnType" mixed="true"><xsd:complexContent><xsd:extension base="ChildrenOnlyType" /></xsd:complexContent></xsd:complexType>
  <xsd:element name="Column" type="ColumnType" />
  
  <xsd:complexType name="ColumnsType" mixed="true"><xsd:complexContent><xsd:extension base="ChildrenOnlyType" /></xsd:complexContent></xsd:complexType>
  <xsd:element name="Columns" type="ColumnsType" />
  
  <xsd:complexType name="GridType" mixed="true"><xsd:complexContent><xsd:extension base="ChildrenOnlyType" /></xsd:complexContent></xsd:complexType>
  <xsd:element name="Grid" type="GridType" />
  
  <xsd:complexType name="DialogType" mixed="true"><xsd:complexContent><xsd:extension base="ChildrenOnlyType" /></xsd:complexContent></xsd:complexType>
  <xsd:element name="Dialog" type="DialogType" />
  
  <xsd:complexType name="DialogContentType" mixed="true"><xsd:complexContent><xsd:extension base="ChildrenOnlyType" /></xsd:complexContent></xsd:complexType>
  <xsd:element name="DialogContent" type="DialogContentType" />
  
  <xsd:complexType name="DialogDescriptionType" mixed="true"><xsd:complexContent><xsd:extension base="ChildrenOnlyType" /></xsd:complexContent></xsd:complexType>
  <xsd:element name="DialogDescription" type="DialogDescriptionType" />
  
  <xsd:complexType name="DialogFooterType" mixed="true"><xsd:complexContent><xsd:extension base="ChildrenOnlyType" /></xsd:complexContent></xsd:complexType>
