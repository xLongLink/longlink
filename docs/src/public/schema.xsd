  </xsd:complexType>

  <xsd:element name="ButtonGroupText" type="ButtonGroupTextType" />
  <xsd:complexType name="ButtonGroupSeparatorType">
    <xsd:attribute name="if" type="xsd:string" use="optional" />
    <xsd:attribute name="orientation" use="optional" default="vertical">
      <xsd:simpleType>
        <xsd:restriction base="xsd:string">
          <xsd:enumeration value="horizontal" />
          <xsd:enumeration value="vertical" />
        </xsd:restriction>
      </xsd:simpleType>
    </xsd:attribute>
  </xsd:complexType>

  <xsd:element name="ButtonGroupSeparator" type="ButtonGroupSeparatorType" />

  <xsd:complexType name="ButtonGroupChildrenOnlyType" mixed="true">
    <xsd:sequence>
      <xsd:choice minOccurs="0" maxOccurs="unbounded">
        <xsd:element ref="Button" />
        <xsd:element ref="Action" />
        <xsd:element ref="Input" />
        <xsd:element ref="ButtonGroupText" />
        <xsd:element ref="ButtonGroupSeparator" />
      </xsd:choice>
    </xsd:sequence>
    <xsd:attribute name="if" type="xsd:string" use="optional" />
  </xsd:complexType>

  <xsd:complexType name="ButtonGroupType" mixed="true">
    <xsd:complexContent>
      <xsd:extension base="ButtonGroupChildrenOnlyType">
        <xsd:attribute name="orientation" use="optional" default="horizontal">
          <xsd:simpleType>
            <xsd:restriction base="xsd:string">
              <xsd:enumeration value="horizontal" />
              <xsd:enumeration value="vertical" />
            </xsd:restriction>
          </xsd:simpleType>
        </xsd:attribute>
      </xsd:extension>
    </xsd:complexContent>
