  <xsd:complexType name="TableHeadType" mixed="true"><xsd:complexContent><xsd:extension base="ChildrenOnlyType" /></xsd:complexContent></xsd:complexType>
  <xsd:element name="TableHead" type="TableHeadType" />
  
  <xsd:complexType name="TableHeaderType" mixed="true"><xsd:complexContent><xsd:extension base="ChildrenOnlyType" /></xsd:complexContent></xsd:complexType>
  <xsd:element name="TableHeader" type="TableHeaderType" />
  
  <xsd:complexType name="TableRowType" mixed="true"><xsd:complexContent><xsd:extension base="ChildrenOnlyType" /></xsd:complexContent></xsd:complexType>
  <xsd:element name="TableRow" type="TableRowType" />
</xsd:schema>
