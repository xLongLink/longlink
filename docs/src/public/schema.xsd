  <xsd:element name="Sup" type="SupType" />
  <xsd:complexType name="SubChildrenOnlyType" mixed="true">
    <xsd:sequence>
      <xsd:choice minOccurs="0" maxOccurs="unbounded">
        <xsd:any processContents="lax" />
