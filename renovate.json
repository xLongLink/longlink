{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["kubernetes"],
  "kubernetes": {
    "managerFilePatterns": ["/^api\\/src\\/kubernetes\\/templates\\/gateway\\.yml$/"]
  },
  "packageRules": [
    {
      "description": "Keep the Envoy gateway image digest-pinned",
      "matchManagers": ["kubernetes"],
      "matchPackageNames": ["envoyproxy/envoy"],
      "pinDigests": true
    }
  ]
}
