<?xml version="1.0" encoding="UTF-8"?>
<Page>
  <Section>
    <Title>{pageTitle}</Title>
    <Text>XML defines the UI tree. React handles rendering and re-renders.</Text>
  </Section>
  <Query id="users" path="http://localhost:8000/users">
    <Section>
      <Title>Fetched With Query</Title>
      <For each="users ?? []" as="user">
        <State id="draft" username="{user.username}">
          <Card>
            <Title>{user.name}</Title>
            <Text>@{user.username}</Text>
            <Text>Role: {user.role}</Text>
            <Text>State snapshot: {draft.username}</Text>
          </Card>
        </State>
      </For>
    </Section>
  </Query>
  <Section>
    <Text>The example exercises top-down context with scope, query data, and local state.</Text>
  </Section>
</Page>
