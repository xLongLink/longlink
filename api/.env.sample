# Session signing key used by the auth cookie.
SESSION_KEY=replace-with-a-long-random-secret

# Public web URL used in account verification and password reset links.
PUBLIC_URL=http://localhost:5173

# Local email/password registration. Development logs emails when SMTP is unset.
AUTH_REGISTRATION_ENABLED=true
# INITIAL_ADMIN_EMAIL=admin@example.com

# SMTP delivery required for production email registration.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=longlink
# SMTP_PASSWORD=replace-with-the-smtp-password
# SMTP_FROM=LongLink <no-reply@example.com>

# Main database used by the LongLink Platform.
# Defaults to a local SQLite file in development.
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# PostgreSQL adapter defaults.
# Use disable for local development; override in deployment if needed.
DATABASE_SSLMODE=disable

# Optional GitHub OAuth example.
# GITHUB_CLIENT_ID=replace-with-the-github-client-id
# GITHUB_CLIENT_SECRET=replace-with-the-github-client-secret

# Optional generic OIDC bridge for internal or B2B deployments.
# OIDC_CLIENT_ID=longlink-api
# OIDC_CLIENT_SECRET=replace-with-the-oidc-client-secret
# OIDC_ISSUER=https://identity.example.com
# OIDC_EMAIL_VERIFIED=true

# Platform-only Exoscale provisioning identity used by Exoscale infrastructure adapters.
# EXOSCALE_API_KEY=EXO...
# EXOSCALE_API_SECRET=replace-with-the-api-secret
# EXOSCALE_ORGANIZATION_ID=00000000-0000-0000-0000-000000000000
