KEY=1234
ORGANIZATION_NAME=LongLink

# Public frontend URL for auth redirects.
# Used when the API sends users back to the web app.
URL=http://localhost:5173

# Main database used by the control plane.
# Defaults to a local SQLite file in development.
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# OIDC settings for login integration.
# These values connect the API to the identity provider.
OIDC_CLIENT_ID=longlink-api
OIDC_CLIENT_SECRET=longlink-secret
OIDC_ISSUER=http://localhost:18080/realms/dev
OIDC_REDIRECT_URI=http://localhost:8000/auth/oidc
OIDC_SCOPES=openid profile email

# PostgreSQL credentials for provisioning tasks.
# Used by the API to create and manage databases.
DATABASE_HOST=localhost
DATABASE_PORT=15432
DATABASE_USERNAME=admin
DATABASE_PASSWORD=admin
DATABASE_MAINTENANCE_DATABASE=postgres
DATABASE_SSLMODE=

# Object storage credentials for provisioning tasks.
# Used by the API to create and manage buckets.
STORAGE_PROTOCOL=file
STORAGE_ENDPOINT_URL=http://localhost:19000
STORAGE_ACCESS_KEY_ID=admin
STORAGE_SECRET_ACCESS_KEY=admin

# Kubernetes and compute provisioning settings.
# Used when applying app workloads to the cluster.
COMPUTE_URL=http://localhost:8080
COMPUTE_KUBE_CONFIG_PATH=kubeconfig.yaml
COMPUTE_NAMESPACE=default
