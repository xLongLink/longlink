DEV=true
KEY=1234

# Control plane database URL
ENV_DATABASE_URL=sqlite+aiosqlite:///./dev.db

# OIDC bridge credentials
ENV_OIDC_CLIENT_ID=longlink-api
ENV_OIDC_CLIENT_SECRET=longlink-secret
ENV_OIDC_ISSUER=http://localhost:18080/realms/dev
ENV_OIDC_REDIRECT_URI=http://localhost:8000/auth/oidc
ENV_OIDC_SCOPES=openid profile email

# Provisioning credentials (configured once, not stored in API DB)
ENV_PROVISION_DATABASE_HOST=localhost
ENV_PROVISION_DATABASE_PORT=15432
ENV_PROVISION_DATABASE_USERNAME=admin
ENV_PROVISION_DATABASE_PASSWORD=admin
ENV_PROVISION_DATABASE_MAINTENANCE_DATABASE=postgres
ENV_PROVISION_DATABASE_SSLMODE=

ENV_PROVISION_STORAGE_ENDPOINT_URL=http://localhost:19000
ENV_PROVISION_STORAGE_ACCESS_KEY_ID=admin
ENV_PROVISION_STORAGE_SECRET_ACCESS_KEY=admin
ENV_PROVISION_STORAGE_REGION_NAME=us-east-1

ENV_PROVISION_COMPUTE_KUBE_API_SERVER=https://localhost:8001
ENV_PROVISION_COMPUTE_KUBE_CONFIG_PATH=/app/kubeconfig
ENV_PROVISION_COMPUTE_NAMESPACE=default
ENV_PROVISION_COMPUTE_VERIFY_SSL=false

# Web URL used for auth redirects
URL=http://localhost:5173
