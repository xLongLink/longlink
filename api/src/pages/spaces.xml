<Page name="Spaces" icon="folder-kanban">
  <Hero
    title="Spaces"
    subtitle="Spaces help organize work into focused environments for your organization."
    icon="folder-kanban"
  />
  <Query id="spaces" path="/apps?type=space">
    <Table>
      <TableHeader>
        <TableRow>
          <TableHead>Name</TableHead>
          <TableHead>URL</TableHead>
          <TableHead>Type</TableHead>
        </TableRow>
      </TableHeader>
      <TableBody>
        <For each="spaces ?? []" as="space">
          <TableRow>
            <TableCell>{space.name}</TableCell>
            <TableCell>{space.url}</TableCell>
            <TableCell>{space.type}</TableCell>
          </TableRow>
        </For>
      </TableBody>
    </Table>
  </Query>
</Page>
