<Page name="Applications" icon="blocks">
  <State id="createApp" appKey="" image="">
    <Hero
      title="Applications"
      subtitle="Manage applications available to your organization."
      icon="blocks"
      action="Create"
    >
      <DialogContent>
        <DialogHeader>
          <DialogTitle>Create application</DialogTitle>
          <DialogDescription>
            Register a new application in this workspace.
          </DialogDescription>
        </DialogHeader>
        <Stack gap="12">
          <Input kind="text" label="App key" bind="createApp.appKey" value="{createApp.appKey}" placeholder="sampleapp" />
          <Input
            kind="text"
            label="Image reference"
            bind="createApp.image"
            value="{createApp.image}"
            placeholder="localhost:5000/sampleapp:20260419_185022"
          />
          <Button
            variant="default"
            action="/apps"
            method="POST"
            payload='{
              "key": "{createApp.appKey}",
              "image": "{createApp.image}"
            }'
            onSuccess="
              refetch(applications);
              set(createApp.appKey, '');
              set(createApp.image, '');
            "
          >
            Create application
          </Button>
        </Stack>
      </DialogContent>
    </Hero>
    <Query id="applications" path="/apps">
      <Table>
        <TableHeader>
          <TableRow>
            <TableHead>Name</TableHead>
            <TableHead>URL</TableHead>
          </TableRow>
        </TableHeader>
        <TableBody>
          <For each="applications ?? []" as="application">
            <TableRow>
              <TableCell>{application.name}</TableCell>
              <TableCell>{application.url}</TableCell>
            </TableRow>
          </For>
        </TableBody>
      </Table>
    </Query>
  </State>
</Page>
