<Page name="People" icon="users">
  <Hero
    title="People"
    subtitle="Invite teammates and collaborators to start working together."
    icon="users"
    action="Add Person"
  />
  <Query id="users" path="/users">
    <Table>
      <TableHeader>
        <TableRow>
          <TableHead>Name</TableHead>
          <TableHead>Email</TableHead>
        </TableRow>
      </TableHeader>
      <TableBody>
        <For each="users ?? []" as="user">
          <TableRow>
            <TableCell>{user.name}</TableCell>
            <TableCell>{user.email}</TableCell>
          </TableRow>
        </For>
      </TableBody>
    </Table>
  </Query>
</Page>
