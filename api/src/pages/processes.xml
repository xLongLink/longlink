<Page name="Processes" icon="workflow">
  <Hero
    title="Processes"
    subtitle="Processes surface reusable workflows and playbooks for your organization."
    icon="workflow"
  />
  <Query id="processes" path="/apps?type=process">
    <Table>
      <TableHeader>
        <TableRow>
          <TableHead>Name</TableHead>
          <TableHead>URL</TableHead>
          <TableHead>Type</TableHead>
        </TableRow>
      </TableHeader>
      <TableBody>
        <For each="processes ?? []" as="process">
          <TableRow>
            <TableCell>{process.name}</TableCell>
            <TableCell>{process.url}</TableCell>
            <TableCell>{process.type}</TableCell>
          </TableRow>
        </For>
      </TableBody>
    </Table>
  </Query>
</Page>
