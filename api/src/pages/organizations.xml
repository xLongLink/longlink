<?xml-model href="https://docs.longlink.dev/schema.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<Page name="Organizations" icon="layout-grid">
  <Query id="organizations" path="/user/organizations" />

  <Hero icon="layout-grid">
    <HeroTitle>
      Organizations
    </HeroTitle>
    <HeroDescription>
      Browse the organizations you belong to and open the workspace you need.
    </HeroDescription>
    <HeroContent>
      <Button action="/organizations/new" variant="default" size="sm">
        Create organization
      </Button>
    </HeroContent>
  </Hero>

  <For each="$organizations.items" as="organization">
    <P>
      {organization.name}
      <Button href="/{organization.name}" variant="outline" size="sm">
        Open
      </Button>
    </P>
  </For>
</Page>
