<Page name="Tools" icon="blocks">
  <Hero
    title="Tools"
    subtitle="Manage the apps and services available to your organization."
    icon="blocks"
  />
  <Query id="tools" path="/apps?type=tool">
    <Table>
      <TableHeader>
        <TableRow>
          <TableHead>Name</TableHead>
          <TableHead>URL</TableHead>
          <TableHead>Type</TableHead>
        </TableRow>
      </TableHeader>
      <TableBody>
        <For each="tools ?? []" as="tool">
          <TableRow>
            <TableCell>{tool.name}</TableCell>
            <TableCell>{tool.url}</TableCell>
            <TableCell>{tool.type}</TableCell>
          </TableRow>
        </For>
      </TableBody>
    </Table>
  </Query>
</Page>
