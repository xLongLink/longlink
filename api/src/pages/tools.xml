<Page name="Tools" icon="blocks">
  <Hero
    title="Tools"
    subtitle="Manage the apps and services available to your organization."
    icon="blocks"
  />
  <Table endpoint="/apps?type=tool">
    <Column key="name" label="Name" content="{name}" link="/{id}" />
    <Column key="url" label="URL" content="{url}" />
    <Column key="type" label="Type" content="{type}" />
  </Table>
</Page>
