<?xml-model href="https://docs.longlink.dev/schema.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<Page name="Settings" icon="settings" xmlns:bind="https://longlink.dev/xml/bind">
  <State id="connectCompute" server="" username="" password="" email="">
    <Menu>
      <MenuSection title="General" icon="settings">
        <MenuSubSection root="true">
          <Input label="Normal Input" placeholder="Lorem ipsum dolor sit amet" description="Lorem ipsum dolor sit amet, consectetur adipiscing elit." submit="Save" />
        </MenuSubSection>
      </MenuSection>
      <MenuSection title="Compute" icon="cpu">
        <MenuSubSection root="true">
          <Hero title="Compute" subtitle="Connect LongLink to your compute cluster." icon="cpu">
            <Dialog>
              <DialogTrigger>Connect</DialogTrigger>
              <DialogContent>
                <DialogHeader>
                  <DialogTitle>Connect compute</DialogTitle>
                  <DialogDescription>
                    Register the compute cluster connection used by LongLink.
                  </DialogDescription>
                </DialogHeader>
                <Stack gap="12">
                  <Input kind="text" label="Server" bind:value="connectCompute.server" placeholder="https://registry.example.com" />
                  <Input kind="text" label="Username" bind:value="connectCompute.username" placeholder="registry-user" />
                  <Input kind="password" label="Password" bind:value="connectCompute.password" placeholder="••••••••" />
                  <Input kind="text" label="Email" bind:value="connectCompute.email" placeholder="user@example.com" />
                  <Button variant="default" action="/compute/registry" method="POST" payload='{
                    "name": "compute",
                    "server": "{connectCompute.server}",
                    "username": "{connectCompute.username}",
                    "password": "{connectCompute.password}",
                    "email": "{connectCompute.email}"
                  }'>
                    Connect
                  </Button>
                </Stack>
              </DialogContent>
            </Dialog>
          </Hero>
        </MenuSubSection>
      </MenuSection>
    </Menu>
  </State>
</Page>
