<?xml-model href="https://docs.longlink.dev/schema.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<Page name="Settings" icon="settings">
  <State id="connectCompute" server="" username="" password="" email="">
    <p>General settings.</p>
    <Input placeholder="Lorem ipsum dolor sit amet" />
    <p>Compute settings.</p>
    <Input value="$connectCompute.server" placeholder="https://registry.example.com" />
    <Input value="$connectCompute.username" placeholder="registry-user" />
    <Input value="$connectCompute.password" placeholder="••••••••" />
    <Input value="$connectCompute.email" placeholder="user@example.com" />
    <Button variant="default" action="/compute/registry" method="POST" payload='{
      "name": "compute",
      "server": "{connectCompute.server}",
      "username": "{connectCompute.username}",
      "password": "{connectCompute.password}",
      "email": "{connectCompute.email}"
    }'>
      Connect
    </Button>
  </State>
</Page>
