<Page name="Settings" icon="settings">
  <Menu>
    <MenuSection title="Applications" icon="app-window">
      <MenuSubSection title="" root="true">
        <Stack gap="24">
          <Hero
            title="Application Settings"
            subtitle="Control app defaults, permissions, and lifecycle settings"
            icon="settings"
            action="Manage applications"
          >
            <DialogContent className="sm:max-w-xl">
              <DialogHeader>
                <DialogTitle>Manage applications</DialogTitle>
                <DialogDescription>
                  Choose how you want to register an application in this workspace.
                </DialogDescription>
              </DialogHeader>
              <Stack gap="12">
                <Card>
                  <CardHeader>
                    <CardTitle>Connect application</CardTitle>
                    <CardDescription>
                      Link an existing deployed app and keep current runtime configuration.
                    </CardDescription>
                  </CardHeader>
                  <CardContent>
                    <Button variant="outline">Connect application</Button>
                  </CardContent>
                </Card>
                <Card>
                  <CardHeader>
                    <CardTitle>Add application</CardTitle>
                    <CardDescription>
                      Create a new application record and configure it for this organization.
                    </CardDescription>
                  </CardHeader>
                  <CardContent>
                    <Button>Add application</Button>
                  </CardContent>
                </Card>
              </Stack>
            </DialogContent>
          </Hero>
          <Query id="apps" path="/apps">
            <Table>
              <TableHeader>
                <TableRow>
                  <TableHead>Name</TableHead>
                  <TableHead>URL</TableHead>
                  <TableHead>Type</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                <For each="apps ?? []" as="app">
                  <TableRow>
                    <TableCell>{app.name}</TableCell>
                    <TableCell>{app.url}</TableCell>
                    <TableCell>{app.type}</TableCell>
                  </TableRow>
                </For>
              </TableBody>
            </Table>
          </Query>
        </Stack>
      </MenuSubSection>
    </MenuSection>

  </Menu>
</Page>
